---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { localizeHref, isLocale, DEFAULT_LOCALE } from '../i18n';
import { contentFor } from '../i18n/content';
import { controlHorarioContent } from '../i18n/extra';

const currentLocale = isLocale(Astro.currentLocale) ? Astro.currentLocale : DEFAULT_LOCALE;
const t = contentFor(controlHorarioContent, currentLocale);
const reasons = t.reasons;
const features = t.features;
const access = t.access;
---

<Layout
  title="Control horario laboral con apps para empresas | Reskyt"
  description="Sistema de Control Horario de Reskyt: registro de la jornada laboral obligatorio desde app móvil, tablet u ordenador, sin inversión ni permanencia."
>
  <Header />
  <main>
    <section class="section hero">
      <div class="container">
        <h1 class="hero-title">{t.titleStart}<span class="red">{t.titleHighlight}</span></h1>
        <p class="hero-text">{t.heroText1}</p>
        <p class="hero-text">{t.heroText2}</p>
      </div>
    </section>

    <section class="section why">
      <div class="container">
        <h2 class="section-title">{t.whyStart}<span class="red">{t.whyHighlight}</span>{t.whyEnd}</h2>
        <div class="cards two">
          {
            reasons.map(({ title, text }) => (
              <article class="card">
                <h3 class="card-title">{title}</h3>
                <p class="card-text">{text}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section funcs soft">
      <div class="container">
        <h2 class="section-title">{t.featuresTitle}</h2>
        <div class="cards">
          {
            features.map(({ title, text }) => (
              <article class="card">
                <h3 class="card-title">{title}</h3>
                <p class="card-text">{text}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section access">
      <div class="container">
        <h2 class="section-title">
          {t.accessTitleStart}<span class="red">{t.accessTitleHighlight}</span>
        </h2>
        <div class="cards three">
          {
            access.map(({ title, text }) => (
              <article class="card">
                <h3 class="card-title">{title}</h3>
                <p class="card-text">{text}</p>
              </article>
            ))
          }
        </div>
        <div class="pricing-cta">
          <p>{t.pricingText}</p>
          <a href={localizeHref('/contacta', currentLocale)} class="btn-primary">{t.pricingCta}</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .hero {
    background-color: var(--color-bg-soft);
  }

  .hero-title {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    letter-spacing: -0.02em;
  }

  .hero-text {
    margin-top: 1rem;
    font-size: 1.1rem;
    color: var(--color-text-muted);
    max-width: 44rem;
  }

  .section-title {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    letter-spacing: -0.02em;
    max-width: 46rem;
    margin-bottom: 2.5rem;
  }

  .funcs.soft {
    background-color: var(--color-bg-soft);
  }

  .cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  .card {
    padding: 1.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background-color: var(--color-bg);
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .why .card,
  .access .card {
    background-color: var(--color-bg-soft);
  }

  .card:hover {
    border-color: var(--color-red);
    transform: translateY(-4px);
  }

  .card-title {
    font-size: 1.1rem;
  }

  .card-text {
    margin-top: 0.7rem;
    font-size: 0.95rem;
    color: var(--color-text-muted);
  }

  .pricing-cta {
    margin-top: 3rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.5rem;
    padding: 2rem;
    border-radius: var(--radius);
    background-color: var(--color-text);
    color: #fff;
  }

  .pricing-cta p {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    font-weight: 600;
  }

  @media (min-width: 60rem) {
    .cards {
      grid-template-columns: repeat(3, 1fr);
    }

    .cards.two {
      grid-template-columns: repeat(2, 1fr);
    }

    .cards.three {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
