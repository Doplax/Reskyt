---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { blogPosts } from '../data/blog-posts';

const featured = blogPosts.slice(0, 2);
const rest = blogPosts.slice(2);

const postUrl = (slug: string) => `/noticias-ecommerce-app/${slug}`;
const postImage = (slug: string) => `/images/blog/${slug}.png`;
---

<Layout
  title="Noticias sobre eCommerce y apps móviles actualizadas | Reskyt"
  description="Tendencias del eCommerce, estrategias de apps móviles, novedades del sector y claves para vender más con tu tienda online en formato app"
>
  <Header />
  <main>
    <section class="section blog">
      <div class="container">
        <h1 class="blog-title">Noticias - Apps para eCommerce</h1>
        <p class="blog-subtitle">
          Las últimas noticias del mundo de las Apps para eCommerce y desarrollo y diseño de
          aplicaciones móviles.
        </p>

        <div class="featured-grid">
          {
            featured.map(({ slug, title, date, readTime }) => (
              <article class="post featured">
                <a
                  href={postUrl(slug)}
                  class="post-image"
                  style={`background-image: url('${postImage(slug)}')`}
                  aria-label={title}
                />
                <a href={postUrl(slug)} class="post-body">
                  <p class="post-meta">
                    <span>{date}</span>
                    <span class="dot">·</span>
                    <span>{readTime} min</span>
                  </p>
                  <h2 class="post-title">{title}</h2>
                </a>
              </article>
            ))
          }
        </div>

        <div class="posts-grid">
          {
            rest.map(({ slug, title, date, readTime }) => (
              <article class="post">
                <a
                  href={postUrl(slug)}
                  class="post-image"
                  style={`background-image: url('${postImage(slug)}')`}
                  aria-label={title}
                />
                <a href={postUrl(slug)} class="post-body">
                  <p class="post-meta">
                    <span>{date}</span>
                    <span class="dot">·</span>
                    <span>{readTime} min</span>
                  </p>
                  <h2 class="post-title">{title}</h2>
                </a>
              </article>
            ))
          }
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .blog-title {
    font-size: clamp(2.25rem, 4.5vw, 3.5rem);
    letter-spacing: -0.02em;
  }

  .blog-subtitle {
    margin-top: 1rem;
    font-size: 1.1rem;
    color: var(--color-text-muted);
    max-width: 40rem;
  }

  .featured-grid {
    margin-top: 3rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .posts-grid {
    margin-top: 1.5rem;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .post {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
    background-color: var(--color-bg-soft);
    transition: transform 0.3s ease, border-color 0.3s ease;
  }

  .post:hover {
    transform: translateY(-6px);
    border-color: var(--color-red);
  }

  .post-image {
    display: block;
    aspect-ratio: 16 / 9;
    background-size: cover;
    background-position: center;
  }

  .post.featured .post-image {
    aspect-ratio: 16 / 8;
  }

  .post-body {
    display: block;
    padding: 1.25rem 1.5rem 1.5rem;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .dot {
    color: var(--color-red);
    font-weight: 700;
  }

  .post-title {
    margin-top: 0.6rem;
    font-size: 1.1rem;
    line-height: 1.35;
    transition: color 0.2s ease;
  }

  .post.featured .post-title {
    font-size: 1.35rem;
  }

  .post:hover .post-title {
    color: var(--color-red);
  }

  @media (max-width: 60rem) {
    .featured-grid {
      grid-template-columns: 1fr;
    }

    .posts-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
