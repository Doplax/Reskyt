---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { localizeHref, isLocale, DEFAULT_LOCALE } from '../i18n';
import { contentFor, formsContent } from '../i18n/content';
import { partnersContent } from '../i18n/extra';

const currentLocale = isLocale(Astro.currentLocale) ? Astro.currentLocale : DEFAULT_LOCALE;
const t = contentFor(partnersContent, currentLocale);
const forms = contentFor(formsContent, currentLocale);
const reasons = t.reasons;
---

<Layout
  title="Partners Reskyt"
  description="Únete al programa Partners de Reskyt: crea las apps de los eCommerce de tus clientes con la plataforma de Appselling y revoluciona sus ventas."
>
  <Header />
  <main>
    <section class="section partners-hero">
      <div class="container">
        <h1 class="hero-title">{t.titleStart}<span class="red">{t.titleHighlight}</span>{t.titleEnd}</h1>
        <p class="hero-lead">{t.lead}</p>
        <p class="hero-text">{t.text}</p>
        <div class="hero-todo">
          <p class="hero-todo-title">{t.todoTitle}</p>
          <ul>
            {t.todoItems.map((item) => <li>{item}</li>)}
          </ul>
        </div>
        <div class="hero-actions">
          <a href={localizeHref('/contacta', currentLocale)} class="btn-primary">{t.cta}</a>
          <div class="hero-contact">
            <p>{forms.mailLine} <a href="mailto:appselling@reskyt.com" class="link-red">appselling@reskyt.com</a></p>
            <p>
              {forms.phoneLine} <a href="tel:+34902731998" class="link-red">+34 902 731 998</a> /
              <a href="tel:+34973949991" class="link-red">+34 973 94 99 91</a>
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="section why">
      <div class="container">
        <h2 class="why-title">{t.whyStart}<span class="red">{t.whyHighlight}</span>?</h2>
        <div class="why-grid">
          {
            reasons.map(({ title, text, highlight }) => (
              <article class="why-card">
                <h3>{title}</h3>
                <p>{text}</p>
                <p class="why-highlight">{highlight}</p>
              </article>
            ))
          }
        </div>
        <p class="why-closing">
          {t.closingStart}<strong>{t.closingBold}</strong>
        </p>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .partners-hero {
    background-color: var(--color-bg-soft);
  }

  .hero-title {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    letter-spacing: -0.02em;
  }

  .hero-lead {
    margin-top: 1.25rem;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.35rem;
  }

  .hero-text {
    margin-top: 1rem;
    color: var(--color-text-muted);
    font-size: 1.1rem;
    max-width: 44rem;
  }

  .hero-todo {
    margin-top: 2rem;
    padding: 1.5rem;
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-red);
    border-radius: 0 var(--radius) var(--radius) 0;
    background-color: var(--color-bg);
    max-width: 40rem;
  }

  .hero-todo-title {
    font-weight: 700;
  }

  .hero-todo ul {
    margin: 0.75rem 0 0;
    padding-left: 1.25rem;
    color: var(--color-text-muted);
    display: grid;
    gap: 0.4rem;
  }

  .hero-actions {
    margin-top: 2rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 2rem;
  }

  .hero-contact {
    display: grid;
    gap: 0.25rem;
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  .link-red {
    color: var(--color-red);
    font-weight: 600;
  }

  .link-red:hover {
    text-decoration: underline;
  }

  .why-title {
    font-size: clamp(2rem, 4vw, 3rem);
    letter-spacing: -0.02em;
  }

  .why-grid {
    margin-top: 3rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  .why-card {
    padding: 2rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background-color: var(--color-bg-soft);
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .why-card:hover {
    border-color: var(--color-red);
    transform: translateY(-4px);
  }

  .why-card h3 {
    font-size: 1.15rem;
  }

  .why-card p {
    margin-top: 0.75rem;
    font-size: 0.95rem;
    color: var(--color-text-muted);
  }

  .why-highlight {
    font-weight: 700;
    color: var(--color-red) !important;
  }

  .why-closing {
    margin-top: 3rem;
    font-size: 1.1rem;
    color: var(--color-text-muted);
    max-width: 44rem;
  }

  @media (min-width: 60rem) {
    .why-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
