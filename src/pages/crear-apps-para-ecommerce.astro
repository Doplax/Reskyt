---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import TechMarquee from '../components/TechMarquee.astro';
import DemoCta from '../components/DemoCta.astro';
import Footer from '../components/Footer.astro';
import { contentFor, funcionalidadesContent } from '../i18n/content';
import { miscContent } from '../i18n/extra';

const t = contentFor(miscContent, Astro.currentLocale);
const func = contentFor(funcionalidadesContent, Astro.currentLocale);

const base = t.crearBase;
const conversion = func.conversionCards;
const segmentation = func.pushCards;
---

<Layout
  title="Crear apps móviles personalizadas para eCommerce | Reskyt"
  description="La plataforma de creación de Apps con más funcionalidades del mercado: no-code, notificaciones push segmentadas, checkouts, buscadores, chatbots y más."
>
  <Header />
  <main>
    <section class="section hero">
      <div class="container">
        <h1 class="hero-title">
          {t.crearHeroStart}<span class="red">{t.crearHeroHighlight}</span>{t.crearHeroEnd}
        </h1>
        <p class="hero-subtitle">{t.crearSubtitle}</p>
      </div>
    </section>

    <section class="section features">
      <div class="container">
        <div class="cards two">
          {
            base.map(({ title, text }) => (
              <article class="card">
                <h2 class="card-title">{title}</h2>
                <p class="card-text">{text}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <TechMarquee />

    <section class="section features">
      <div class="container">
        <h2 class="section-title">{func.convStart}<span class="red">{func.convHighlight}</span>{func.convEnd}</h2>
        <div class="cards">
          {
            conversion.map(({ title, text }) => (
              <article class="card">
                <h3 class="card-title">{title}</h3>
                <p class="card-text">{text}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section features soft">
      <div class="container">
        <h2 class="section-title">{func.pushStart}<span class="red">{func.pushHighlight}</span>{func.pushEnd}</h2>
        <div class="cards">
          {
            segmentation.map(({ title, text }) => (
              <article class="card">
                <h3 class="card-title">{title}</h3>
                <p class="card-text">{text}</p>
              </article>
            ))
          }
        </div>
        <div class="reviews">
          <h3 class="reviews-title">{t.crearReviewsTitle}</h3>
          <p class="reviews-text">{t.crearReviewsText}</p>
        </div>
      </div>
    </section>

    <DemoCta />
  </main>
  <Footer />
</Layout>

<style>
  .hero {
    padding-bottom: 1rem;
  }

  .hero-title {
    font-size: clamp(2.25rem, 4.5vw, 3.5rem);
    letter-spacing: -0.02em;
    max-width: 54rem;
  }

  .hero-subtitle {
    margin-top: 1.5rem;
    font-size: 1.15rem;
    color: var(--color-text-muted);
    max-width: 40rem;
  }

  .features.soft {
    background-color: var(--color-bg-soft);
  }

  .section-title {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    letter-spacing: -0.02em;
    max-width: 46rem;
    margin-bottom: 2.5rem;
  }

  .cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  .card {
    padding: 2rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background-color: var(--color-bg);
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .features:not(.soft) .card {
    background-color: var(--color-bg-soft);
  }

  .card:hover {
    border-color: var(--color-red);
    transform: translateY(-4px);
  }

  .card-title {
    font-size: 1.15rem;
  }

  .card-text {
    margin-top: 0.75rem;
    font-size: 0.95rem;
    color: var(--color-text-muted);
  }

  .reviews {
    margin-top: 3rem;
    padding: 2rem;
    border-radius: var(--radius);
    background-color: var(--color-text);
    color: #fff;
  }

  .reviews-title {
    font-size: 1.35rem;
  }

  .reviews-text {
    margin-top: 0.75rem;
    color: rgba(255, 255, 255, 0.75);
    max-width: 44rem;
  }

  @media (min-width: 60rem) {
    .cards {
      grid-template-columns: repeat(3, 1fr);
    }

    .cards.two {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
