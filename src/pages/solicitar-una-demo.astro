---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const benefits = [
  { title: 'Demo personalizada', text: 'Te enseñamos la app con el catálogo de tu propio eCommerce.' },
  { title: 'Sin compromiso', text: '30 minutos con nuestro equipo, sin permanencias ni letra pequeña.' },
  { title: 'Lanzamiento en 4 semanas', text: 'Si te convence, tu app puede estar publicada en menos de un mes.' },
];
---

<Layout
  title="Solicita una demo | Reskyt"
  description="Agenda una demo personalizada y descubre cómo convertir tu eCommerce en una app nativa en menos de 4 semanas."
>
  <Header />
  <main>
    <section class="section demo">
      <div class="container demo-grid">
        <div class="demo-intro">
          <h1 class="demo-title">Agenda tu <span class="red">demo</span> ahora</h1>
          <p class="demo-subtitle">
            Introduce tus datos y en breve nos pondremos en contacto contigo.
          </p>

          <ul class="demo-benefits">
            {
              benefits.map(({ title, text }) => (
                <li class="demo-benefit">
                  <span class="demo-benefit-check" aria-hidden="true">
                    <svg viewBox="0 0 16 16" width="14" height="14" fill="none">
                      <path d="M2.5 8.5l3.5 3.5 7.5-8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                  </span>
                  <div>
                    <p class="demo-benefit-title">{title}</p>
                    <p class="demo-benefit-text">{text}</p>
                  </div>
                </li>
              ))
            }
          </ul>

          <div class="demo-contact">
            <p>Envía un mail a <a href="mailto:appselling@reskyt.com" class="demo-link">appselling@reskyt.com</a></p>
            <p>
              Llámanos al <a href="tel:+34902731998" class="demo-link">+34 902 731 998</a> /
              <a href="tel:+34973949991" class="demo-link">+34 973 94 99 91</a>
            </p>
          </div>
        </div>

        <form class="demo-form" id="demo-form" novalidate>
          <div class="form-row">
            <div class="form-field">
              <label for="nombre">Nombre</label>
              <input type="text" id="nombre" name="nombre" autocomplete="name" placeholder="Ana García" required />
            </div>
            <div class="form-field">
              <label for="empresa">Empresa</label>
              <input type="text" id="empresa" name="empresa" autocomplete="organization" placeholder="Mi Tienda SL" required />
            </div>
          </div>

          <div class="form-row">
            <div class="form-field">
              <label for="email">E-mail</label>
              <input type="email" id="email" name="email" autocomplete="email" placeholder="ana@mitienda.com" required />
            </div>
            <div class="form-field">
              <label for="telefono">Teléfono <span class="optional">(opcional)</span></label>
              <input type="tel" id="telefono" name="telefono" autocomplete="tel" placeholder="600 000 000" />
            </div>
          </div>

          <div class="form-field">
            <label for="url">URL de tu eCommerce</label>
            <input type="url" id="url" name="url" inputmode="url" placeholder="https://www.mitienda.com" required />
          </div>

          <label class="form-check">
            <input type="checkbox" name="terminos" required />
            <span class="form-check-box" aria-hidden="true"></span>
            <span>Acepto los <a href="/condiciones-generales" class="demo-link">términos y condiciones</a></span>
          </label>

          <button type="submit" class="btn-primary form-submit">Pide tu demo</button>

          <p class="form-error" id="form-error" hidden>Revisa los campos marcados: falta algún dato o no es válido.</p>
          <p class="form-note">*Válido para no clientes. Una app por empresa.</p>
        </form>

        <div class="demo-success" id="demo-success" hidden>
          <span class="demo-success-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="28" height="28" fill="none">
              <path d="M4 12.5l5.5 5.5L20 6.5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
          <h2 class="demo-success-title">¡Solicitud enviada!</h2>
          <p>Gracias por tu interés. Nuestro equipo te contactará en menos de 24 h laborables.</p>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .demo {
    background:
      radial-gradient(40rem 25rem at 110% -10%, rgba(213, 21, 33, 0.07), transparent),
      var(--color-bg-soft);
  }

  .demo-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }

  .demo-title {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    letter-spacing: -0.02em;
  }

  .demo-subtitle {
    margin-top: 1rem;
    font-size: 1.1rem;
    color: var(--color-text-muted);
    max-width: 30rem;
  }

  .demo-benefits {
    margin: 2rem 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 1.25rem;
  }

  .demo-benefit {
    display: flex;
    gap: 0.85rem;
    align-items: flex-start;
  }

  .demo-benefit-check {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    margin-top: 0.15rem;
    border-radius: 50%;
    background-color: rgba(213, 21, 33, 0.1);
    color: var(--color-red);
  }

  .demo-benefit-title {
    font-weight: 600;
  }

  .demo-benefit-text {
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  .demo-contact {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
    display: grid;
    gap: 0.35rem;
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  .demo-link {
    color: var(--color-red);
    font-weight: 600;
  }

  .demo-link:hover {
    text-decoration: underline;
  }

  /* El display de abajo pisaría el atributo hidden sin esta regla */
  .demo-form[hidden],
  .demo-intro[hidden] {
    display: none;
  }

  .demo-form {
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: calc(var(--radius) * 1.25);
    padding: 1.75rem;
    box-shadow: 0 1.5rem 3rem rgba(22, 22, 26, 0.07);
    display: grid;
    gap: 1.25rem;
    align-self: start;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  .form-field {
    display: grid;
    gap: 0.4rem;
  }

  .form-field label {
    font-size: 0.9rem;
    font-weight: 600;
  }

  .optional {
    font-weight: 400;
    color: var(--color-text-muted);
  }

  .form-field input {
    width: 100%;
    padding: 0.8rem 1rem;
    font: inherit;
    font-size: 0.95rem;
    color: var(--color-text);
    background-color: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    border-radius: 0.6rem;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .form-field input::placeholder {
    color: #a7a7b0;
  }

  .form-field input:focus {
    outline: none;
    border-color: var(--color-red);
    box-shadow: 0 0 0 3px rgba(213, 21, 33, 0.12);
    background-color: var(--color-bg);
  }

  .demo-form.was-validated input:invalid {
    border-color: var(--color-red);
    background-color: rgba(213, 21, 33, 0.04);
  }

  .form-check {
    display: flex;
    align-items: flex-start;
    gap: 0.65rem;
    font-size: 0.9rem;
    cursor: pointer;
    user-select: none;
  }

  .form-check input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .form-check-box {
    flex-shrink: 0;
    width: 1.25rem;
    height: 1.25rem;
    margin-top: 0.1rem;
    border: 1.5px solid var(--color-border);
    border-radius: 0.35rem;
    background-color: var(--color-bg-soft);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.15s ease, border-color 0.15s ease;
  }

  .form-check-box::after {
    content: '';
    width: 0.65rem;
    height: 0.35rem;
    border-left: 2px solid #fff;
    border-bottom: 2px solid #fff;
    transform: rotate(-45deg) translate(1px, -1px);
    opacity: 0;
  }

  .form-check input:checked + .form-check-box {
    background-color: var(--color-red);
    border-color: var(--color-red);
  }

  .form-check input:checked + .form-check-box::after {
    opacity: 1;
  }

  .form-check input:focus-visible + .form-check-box {
    box-shadow: 0 0 0 3px rgba(213, 21, 33, 0.12);
  }

  .demo-form.was-validated .form-check input:invalid + .form-check-box {
    border-color: var(--color-red);
  }

  .form-submit {
    border: 0;
    cursor: pointer;
    font-size: 1rem;
    padding-block: 0.95rem;
  }

  .form-error {
    color: var(--color-red);
    font-size: 0.9rem;
  }

  .form-note {
    color: var(--color-text-muted);
    font-size: 0.8rem;
    text-align: center;
  }

  .demo-success {
    grid-column: 1 / -1;
    justify-self: center;
    max-width: 26rem;
    text-align: center;
    padding: 2.5rem 1.5rem;
    color: var(--color-text-muted);
  }

  .demo-success-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 50%;
    background-color: rgba(213, 21, 33, 0.1);
    color: var(--color-red);
  }

  .demo-success-title {
    margin-top: 1rem;
    margin-bottom: 0.5rem;
    color: var(--color-text);
    font-size: 1.5rem;
  }

  /* A partir de tablet: dos columnas y formulario con campos emparejados */
  @media (min-width: 48rem) {
    .form-row {
      grid-template-columns: 1fr 1fr;
    }

    .demo-form {
      padding: 2.25rem;
    }
  }

  @media (min-width: 60rem) {
    .demo-grid {
      grid-template-columns: 1fr 1.05fr;
      gap: 4rem;
      align-items: start;
    }
  }
</style>

<script>
  const form = document.getElementById('demo-form') as HTMLFormElement | null;
  const success = document.getElementById('demo-success');
  const error = document.getElementById('form-error');

  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    form.classList.add('was-validated');

    if (!form.checkValidity()) {
      error?.removeAttribute('hidden');
      return;
    }

    // Réplica estática: no hay backend, mostramos la confirmación directamente.
    form.hidden = true;
    error?.setAttribute('hidden', '');
    document.querySelector('.demo-intro')?.setAttribute('hidden', '');
    success?.removeAttribute('hidden');
  });
</script>
