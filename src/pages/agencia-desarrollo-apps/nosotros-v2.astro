---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { contentFor } from '../../i18n/content';
import { aboutContent } from '../../i18n/about-cases';

const t = contentFor(aboutContent, Astro.currentLocale);
const valores = t.valores;

type TimelineEntry = { badge?: string; text?: string };

// El hito de cada año intercala insignias y textos: primera insignia, textos y resto de insignias.
const timeline: { year: string; entries: TimelineEntry[] }[] = Object.entries(t.timeline).map(
  ([year, { badges = [], texts }]) => ({
    year,
    entries: [
      ...badges.slice(0, 1).map((badge) => ({ badge })),
      ...texts.map((text) => ({ text })),
      ...badges.slice(1).map((badge) => ({ badge })),
    ],
  })
);
---

<Layout
  title="Somos especialistas en apps eCommerce para agencias | Reskyt"
  description="Conoce al equipo que desarrolla apps nativas para tiendas online, su experiencia con agencias y cómo colaboramos para lograr éxito en el canal app"
>
  <Header />
  <main>
    <section class="section about">
      <div class="container">
        <h1 class="about-title">
          {t.titleStart}<span class="red">{t.titleHighlight}</span>{t.titleEnd}
        </h1>
        <p class="about-lead">{t.lead}</p>

        <div class="about-grid">
          <div class="about-gallery">
            <img
              src="/images/about/conferencia.webp"
              alt="Descubre la historia de Reskyt, agencia de desarrollo de apps líder"
              loading="lazy"
              width="1199"
            />
            <div class="about-gallery-row">
              <img
                src="/images/about/premio-ecommerce-tools.jpg"
                alt="Ganadores a la mejor plataforma para eCommerce en la gala eCommerce Tools"
                loading="lazy"
                width="600"
              />
              <img
                src="/images/about/premio-eawards.webp"
                alt="Ganadores de los premios eAwards a la mejor agencia de creación de apps"
                loading="lazy"
                width="600"
              />
              <img
                class="about-gallery-wide"
                src="/images/about/feria-eshow.webp"
                alt="El equipo de Reskyt en la feria eShow de Barcelona"
                loading="lazy"
                width="760"
              />
            </div>
          </div>

          <div class="about-description">
            {t.description.map((paragraph) => <p>{paragraph}</p>)}
          </div>
        </div>

        <div class="about-closing">
          <p>{t.closing[0]}</p>
          <p><strong>{t.closingBold}</strong></p>
          <p>{t.closing[1]}</p>
        </div>
      </div>
    </section>

    <section class="section values">
      <div class="container">
        <h2 class="values-title">{t.valoresTitle}</h2>
        <div class="values-grid">
          {
            valores.map(({ title, text }) => (
              <div class="value">
                <h3 class="value-title">{title}</h3>
                <p class="value-text">{text}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section goals">
      <div class="container">
        <h2 class="goals-title">{t.objetivosStart}<span class="red">{t.objetivosHighlight}</span></h2>
        <p class="goals-text">{t.objetivosText}</p>
      </div>
    </section>

    <section class="section evolution">
      <div class="container">
        <h2 class="evolution-title">{t.evolucionStart}<span class="red">{t.evolucionHighlight}</span></h2>

        <div class="timeline" id="timeline">
          <div class="timeline-track" aria-hidden="true">
            <div class="timeline-fill" id="timeline-fill"></div>
          </div>
          {
            timeline.map(({ year, entries }) => (
              <div class="timeline-item">
                <p class="timeline-year">{year}</p>
                <div class="timeline-dot" aria-hidden="true" />
                <div class="timeline-content">
                  {entries.map(({ badge, text }) =>
                    badge ? <p class="timeline-badge">{badge}</p> : <p class="timeline-text">{text}</p>
                  )}
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .about {
    background-color: var(--color-bg-soft);
  }

  .about-title {
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    letter-spacing: -0.02em;
    max-width: 52rem;
  }

  .about-lead {
    margin-top: 1.5rem;
    font-size: 1.1rem;
    color: var(--color-text-muted);
    max-width: 44rem;
  }

  .about-grid {
    margin-top: 3rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: start;
  }

  .about-gallery img {
    border-radius: var(--radius);
    width: 100%;
  }

  .about-gallery-row {
    margin-top: 1rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .about-gallery-wide {
    grid-column: 1 / -1;
  }

  .about-description {
    display: grid;
    gap: 1.25rem;
    color: var(--color-text-muted);
    font-size: 1.05rem;
  }

  .about-closing {
    margin-top: 2.5rem;
    display: grid;
    gap: 1.25rem;
    max-width: 52rem;
    color: var(--color-text-muted);
    font-size: 1.05rem;
  }

  .about-closing strong {
    color: var(--color-text);
  }

  .values {
    background-color: var(--color-text);
    color: #fff;
  }

  .values-title {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    letter-spacing: -0.02em;
    max-width: 32rem;
  }

  .values-grid {
    margin-top: 3rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  .value-title {
    font-size: 1.35rem;
    color: var(--color-red);
  }

  .value-text {
    margin-top: 0.75rem;
    color: rgba(255, 255, 255, 0.75);
  }

  .goals-title {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    letter-spacing: -0.02em;
  }

  .goals-text {
    margin-top: 1.25rem;
    max-width: 52rem;
    font-size: 1.1rem;
    color: var(--color-text-muted);
  }

  .evolution {
    background-color: var(--color-bg-soft);
  }

  .evolution-title {
    font-size: clamp(2rem, 4vw, 3rem);
    letter-spacing: -0.02em;
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .timeline {
    position: relative;
    max-width: 56rem;
    margin-inline: auto;
  }

  .timeline-track {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0.4375rem;
    width: 2px;
    background-color: var(--color-border);
  }

  .timeline-fill {
    width: 100%;
    height: 0%;
    background-color: var(--color-red);
    transition: height 0.15s linear;
  }

  .timeline-item {
    position: relative;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
    padding-left: 2.5rem;
    padding-bottom: 3rem;
  }

  .timeline-dot {
    position: absolute;
    left: 0;
    top: 0.35rem;
    width: 1rem;
    height: 1rem;
    border-radius: 50%;
    background-color: var(--color-red);
    box-shadow: 0 0 0 4px rgba(213, 21, 33, 0.15);
  }

  .timeline-year {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    font-weight: 600;
    line-height: 1;
  }

  .timeline-content {
    display: grid;
    gap: 0.85rem;
    justify-items: start;
  }

  .timeline-badge {
    display: inline-block;
    padding: 0.35rem 0.9rem;
    border-radius: 999px;
    background-color: rgba(213, 21, 33, 0.08);
    border: 1px solid rgba(213, 21, 33, 0.25);
    color: var(--color-red);
    font-size: 0.85rem;
    font-weight: 600;
  }

  .timeline-text {
    color: var(--color-text-muted);
  }

  @media (min-width: 60rem) {
    .about-grid {
      grid-template-columns: 1.15fr 1fr;
      gap: 4rem;
    }

    .values-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .timeline-track {
      left: calc(8rem + 0.4375rem);
    }

    .timeline-item {
      grid-template-columns: 6rem 1fr;
      gap: 0 4.5rem;
      padding-left: 0;
    }

    .timeline-dot {
      left: 8rem;
    }

    .timeline-year {
      text-align: right;
      font-size: 2rem;
    }
  }
</style>

<script>
  // La línea de la cronología se va rellenando en rojo a medida que se hace scroll.
  const timeline = document.getElementById('timeline');
  const fill = document.getElementById('timeline-fill');

  function updateFill() {
    if (!timeline || !fill) return;
    const rect = timeline.getBoundingClientRect();
    const viewportAnchor = window.innerHeight * 0.6;
    const progress = Math.min(Math.max((viewportAnchor - rect.top) / rect.height, 0), 1);
    fill.style.height = `${progress * 100}%`;
  }

  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    fill?.style.setProperty('height', '100%');
  } else {
    updateFill();
    window.addEventListener('scroll', updateFill, { passive: true });
    window.addEventListener('resize', updateFill, { passive: true });
  }
</script>
