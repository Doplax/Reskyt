---
// Login interno del panel de administración (maqueta: el envío es simulado en cliente).
import '../../styles/global.css';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="robots" content="noindex,nofollow" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Accede a tu panel | Reskyt</title>
    <link rel="icon" type="image/svg+xml" href="/images/admin/favicon-admin.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <main class="login">
      <!-- Panel de marca -->
      <aside class="brand-panel" aria-hidden="true">
        <div class="brand-glow glow-1"></div>
        <div class="brand-glow glow-2"></div>
        <svg class="brand-mark" viewBox="0 0 105 83" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path
            fill-rule="evenodd"
            clip-rule="evenodd"
            d="M52.3281 0.260742H41.7637L0 41.5885V61.9421L21.7261 82.8542H82.9301L104.656 61.9421V41.5885L62.8924 0.260742H52.3281ZM82.9301 62.7458V49.6555L52.3281 19.3423L21.7261 49.6555V62.7458L82.9301 62.7458Z"
            fill="currentColor"
          />
        </svg>

        <div class="brand-content">
          <img class="brand-logo" src="/images/logo-reskyt.svg" alt="" width="150" height="35" />

          <h1 class="brand-title">Tu tienda, <span class="red">tu app</span>,<br />tus reglas.</h1>
          <p class="brand-copy">
            Gestiona las notificaciones push, el contenido y el diseño de tu app desde un único
            panel. Sin programar, sin complicaciones.
          </p>

          <ul class="brand-points">
            <li>
              <span class="point-icon">✓</span>
              Notificaciones push ilimitadas
            </li>
            <li>
              <span class="point-icon">✓</span>
              Sincronización en tiempo real con tu eCommerce
            </li>
            <li>
              <span class="point-icon">✓</span>
              Publicación en App Store y Google Play
            </li>
          </ul>
        </div>

        <p class="brand-quote">
          «La app se ha convertido en nuestro canal con mayor conversión.»
          <span class="quote-author">— Clientes que ya venden más con Reskyt</span>
        </p>
      </aside>

      <!-- Panel del formulario -->
      <section class="form-panel">
        <header class="form-header">
          <a class="back-link" href="/">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M10 3 5 8l5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            Volver a la web
          </a>
          <img class="mobile-logo" src="/images/logo-reskyt.svg" alt="Reskyt" width="120" height="28" />
        </header>

        <div class="form-wrap">
          <!-- Vista: login -->
          <div class="view" id="view-login">
            <p class="eyebrow">Panel de administración</p>
            <h2 class="form-title">Bienvenido de nuevo</h2>
            <p class="form-subtitle">Accede para gestionar tu app y tus notificaciones.</p>

            <form id="form-login" novalidate>
              <div class="field">
                <label for="username">Usuario o e-mail</label>
                <div class="control">
                  <svg class="control-icon" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                    <circle cx="10" cy="6.5" r="3.25" stroke="currentColor" stroke-width="1.5" />
                    <path d="M3.5 17c.9-3 3.5-4.5 6.5-4.5s5.6 1.5 6.5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                  </svg>
                  <input
                    type="text"
                    id="username"
                    name="username"
                    placeholder="tu@empresa.com"
                    autocomplete="username"
                    required
                  />
                </div>
                <p class="field-error" data-error-for="username" hidden>Introduce tu usuario o e-mail.</p>
              </div>

              <div class="field">
                <label for="password">Contraseña</label>
                <div class="control">
                  <svg class="control-icon" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                    <rect x="4" y="8.5" width="12" height="8" rx="2" stroke="currentColor" stroke-width="1.5" />
                    <path d="M7 8.5V6.75a3 3 0 0 1 6 0V8.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                  </svg>
                  <input
                    type="password"
                    id="password"
                    name="password"
                    placeholder="••••••••"
                    autocomplete="current-password"
                    required
                  />
                  <button type="button" class="toggle-password" aria-label="Mostrar contraseña" aria-pressed="false">
                    <svg class="icon-eye" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                      <path d="M2 10s3-5.5 8-5.5S18 10 18 10s-3 5.5-8 5.5S2 10 2 10Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" />
                      <circle cx="10" cy="10" r="2.25" stroke="currentColor" stroke-width="1.5" />
                    </svg>
                    <svg class="icon-eye-off" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                      <path d="M2 10s3-5.5 8-5.5S18 10 18 10s-3 5.5-8 5.5S2 10 2 10Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" />
                      <circle cx="10" cy="10" r="2.25" stroke="currentColor" stroke-width="1.5" />
                      <path d="m4 16 12-12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                    </svg>
                  </button>
                </div>
                <p class="field-error" data-error-for="password" hidden>Introduce tu contraseña.</p>
                <p class="caps-hint" id="caps-hint" hidden>
                  <svg viewBox="0 0 16 16" fill="none" aria-hidden="true" width="13" height="13">
                    <path d="M8 5.5v3.75M8 11.5h.01" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
                    <circle cx="8" cy="8" r="6.25" stroke="currentColor" stroke-width="1.4" />
                  </svg>
                  Bloq Mayús activado
                </p>
              </div>

              <div class="form-row">
                <label class="remember">
                  <input type="checkbox" id="remember" name="remember" />
                  <span class="checkmark" aria-hidden="true">
                    <svg viewBox="0 0 12 12" fill="none">
                      <path d="M2.5 6.5 5 9l4.5-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                  </span>
                  Recordarme
                </label>
                <a class="link" href="#" id="show-forgot">¿Has olvidado tu contraseña?</a>
              </div>

              <button class="btn-submit" type="submit">
                <span class="btn-label">Entrar</span>
                <span class="btn-spinner" aria-hidden="true"></span>
              </button>
            </form>

            <p class="alt-action">
              ¿Aún no tienes tu app? <a class="link link-strong" href="/contacta">Solicita una demo</a>
            </p>
          </div>

          <!-- Vista: recuperar contraseña -->
          <div class="view" id="view-forgot" hidden>
            <p class="eyebrow">Recuperar acceso</p>
            <h2 class="form-title">¿Olvidaste tu contraseña?</h2>
            <p class="form-subtitle">
              Escribe tu usuario o e-mail y te enviaremos un enlace para restablecerla.
            </p>

            <form id="form-forgot" novalidate>
              <div class="field">
                <label for="forgot-email">Usuario o e-mail</label>
                <div class="control">
                  <svg class="control-icon" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                    <rect x="2.75" y="4.75" width="14.5" height="10.5" rx="2" stroke="currentColor" stroke-width="1.5" />
                    <path d="m3.5 6 6.5 5 6.5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                  <input
                    type="text"
                    id="forgot-email"
                    name="forgot-email"
                    placeholder="tu@empresa.com"
                    autocomplete="username"
                    required
                  />
                </div>
                <p class="field-error" data-error-for="forgot-email" hidden>Introduce tu usuario o e-mail.</p>
              </div>

              <button class="btn-submit" type="submit">
                <span class="btn-label">Enviar enlace</span>
                <span class="btn-spinner" aria-hidden="true"></span>
              </button>
            </form>

            <p class="forgot-note">
              Si no recuerdas el usuario o e-mail asociado a Reskyt escríbenos a
              <a class="link link-strong" href="mailto:info@reskyt.com">info@reskyt.com</a>
            </p>

            <p class="alt-action">
              <a class="link link-strong" href="#" id="show-login">← Volver al inicio de sesión</a>
            </p>
          </div>

          <!-- Vista: enlace enviado -->
          <div class="view view-center" id="view-sent" hidden>
            <div class="success-badge" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none">
                <path class="check-path" d="M5 12.5 10 17.5 19 7" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </div>
            <h2 class="form-title">Revisa tu bandeja de entrada</h2>
            <p class="form-subtitle">
              Hemos enviado un enlace de recuperación a <strong id="sent-email"></strong>. Si no lo
              ves, mira en la carpeta de spam.
            </p>
            <p class="alt-action">
              <a class="link link-strong" href="#" id="sent-back">← Volver al inicio de sesión</a>
            </p>
          </div>

          <!-- Vista: sesión iniciada (demo) -->
          <div class="view view-center" id="view-success" hidden>
            <div class="success-badge" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none">
                <path class="check-path" d="M5 12.5 10 17.5 19 7" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </div>
            <h2 class="form-title">¡Hola de nuevo<span id="success-name"></span>!</h2>
            <p class="form-subtitle">Sesión iniciada correctamente. Cargando tu panel…</p>
            <p class="demo-note">Maqueta: el inicio de sesión es simulado.</p>
            <p class="alt-action">
              <a class="link link-strong" href="#" id="success-back">← Cerrar sesión</a>
            </p>
          </div>
        </div>

        <footer class="form-footer">
          <p>© {new Date().getFullYear()} Reskyt · <a class="link" href="/">reskyt.com</a></p>
        </footer>
      </section>
    </main>
  </body>
</html>

<style>
  body {
    min-height: 100vh;
  }

  .login {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr);
    min-height: 100vh;
  }

  /* ---------- Panel de marca ---------- */

  .brand-panel {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 3rem;
    padding: 3.5rem 4rem;
    background-color: var(--color-text);
    color: #fff;
    overflow: hidden;
  }

  .brand-glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(90px);
    opacity: 0.5;
    pointer-events: none;
  }

  .glow-1 {
    width: 30rem;
    height: 30rem;
    top: -12rem;
    right: -10rem;
    background: radial-gradient(circle, rgba(213, 21, 33, 0.55), transparent 70%);
  }

  .glow-2 {
    width: 26rem;
    height: 26rem;
    bottom: -10rem;
    left: -8rem;
    background: radial-gradient(circle, rgba(213, 21, 33, 0.35), transparent 70%);
  }

  .brand-mark {
    position: absolute;
    right: -6rem;
    bottom: -5rem;
    width: 26rem;
    color: rgba(255, 255, 255, 0.045);
    pointer-events: none;
  }

  .brand-content {
    position: relative;
    max-width: 30rem;
  }

  .brand-logo {
    filter: brightness(0) invert(1);
    margin-bottom: 3.5rem;
  }

  .brand-title {
    font-size: clamp(2.1rem, 3vw, 2.9rem);
    letter-spacing: -0.02em;
    margin-bottom: 1.25rem;
  }

  .brand-title .red {
    color: #ff4d5a;
  }

  .brand-copy {
    color: rgba(255, 255, 255, 0.72);
    font-size: 1.02rem;
    line-height: 1.7;
    margin-bottom: 2.25rem;
  }

  .brand-points {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    margin: 0;
    padding: 0;
    list-style: none;
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.85);
  }

  .brand-points li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .point-icon {
    display: grid;
    place-items: center;
    width: 1.4rem;
    height: 1.4rem;
    border-radius: 50%;
    background-color: rgba(213, 21, 33, 0.25);
    color: #ff8b94;
    font-size: 0.75rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  .brand-quote {
    position: relative;
    max-width: 26rem;
    font-size: 0.95rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.65);
    border-left: 2px solid rgba(213, 21, 33, 0.7);
    padding-left: 1.1rem;
  }

  .quote-author {
    display: block;
    margin-top: 0.4rem;
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.45);
  }

  /* ---------- Panel del formulario ---------- */

  .form-panel {
    display: flex;
    flex-direction: column;
    padding: 2rem 3rem;
    background-color: var(--color-bg);
  }

  .form-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-muted);
    transition: color 0.2s ease;
  }

  .back-link:hover {
    color: var(--color-red);
  }

  .mobile-logo {
    display: none;
  }

  .form-wrap {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    width: 100%;
    max-width: 24.5rem;
    margin-inline: auto;
    padding-block: 3rem;
  }

  .view {
    animation: view-in 0.35s ease both;
  }

  .view-center {
    text-align: center;
  }

  @keyframes view-in {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-red);
    margin-bottom: 0.75rem;
  }

  .form-title {
    font-size: clamp(1.7rem, 2.4vw, 2.1rem);
    letter-spacing: -0.01em;
    margin-bottom: 0.6rem;
  }

  .form-subtitle {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    margin-bottom: 2.25rem;
  }

  form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .field label {
    font-size: 0.85rem;
    font-weight: 500;
  }

  .control {
    position: relative;
    display: flex;
    align-items: center;
  }

  .control-icon {
    position: absolute;
    left: 0.9rem;
    width: 1.1rem;
    height: 1.1rem;
    color: #a3a3ac;
    pointer-events: none;
    transition: color 0.2s ease;
  }

  .control:focus-within .control-icon {
    color: var(--color-red);
  }

  .control input {
    width: 100%;
    padding: 0.8rem 1rem 0.8rem 2.7rem;
    border: 1px solid var(--color-border);
    border-radius: 0.65rem;
    background-color: var(--color-bg-soft);
    font-family: inherit;
    font-size: 0.95rem;
    color: var(--color-text);
    transition: border-color 0.2s ease, background-color 0.2s ease, box-shadow 0.2s ease;
  }

  .control input::placeholder {
    color: #a3a3ac;
  }

  .control input:focus {
    outline: none;
    border-color: var(--color-red);
    background-color: var(--color-bg);
    box-shadow: 0 0 0 3px rgba(213, 21, 33, 0.12);
  }

  .field.has-error .control input {
    border-color: var(--color-red);
    background-color: #fdf3f4;
  }

  .field.has-error.shake .control {
    animation: shake 0.35s ease;
  }

  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-5px); }
    50% { transform: translateX(5px); }
    75% { transform: translateX(-3px); }
  }

  .field-error {
    font-size: 0.8rem;
    color: var(--color-red);
  }

  .caps-hint[hidden] {
    display: none;
  }

  .caps-hint {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.8rem;
    color: #9a6700;
  }

  .toggle-password {
    position: absolute;
    right: 0.55rem;
    display: grid;
    place-items: center;
    width: 2rem;
    height: 2rem;
    border: 0;
    border-radius: 0.5rem;
    background: none;
    color: #a3a3ac;
    cursor: pointer;
    transition: color 0.2s ease, background-color 0.2s ease;
  }

  .toggle-password:hover {
    color: var(--color-text);
    background-color: rgba(0, 0, 0, 0.05);
  }

  .toggle-password svg {
    width: 1.15rem;
    height: 1.15rem;
  }

  .toggle-password .icon-eye-off,
  .toggle-password[aria-pressed='true'] .icon-eye {
    display: none;
  }

  .toggle-password[aria-pressed='true'] .icon-eye-off {
    display: block;
  }

  .form-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.6rem 1rem;
    margin-top: -0.15rem;
  }

  .remember {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    cursor: pointer;
    user-select: none;
  }

  .remember input {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }

  .checkmark {
    display: grid;
    place-items: center;
    width: 1.15rem;
    height: 1.15rem;
    border: 1.5px solid #c9c9d1;
    border-radius: 0.35rem;
    background-color: var(--color-bg);
    color: #fff;
    transition: background-color 0.15s ease, border-color 0.15s ease;
  }

  .checkmark svg {
    width: 0.7rem;
    height: 0.7rem;
    opacity: 0;
    transform: scale(0.5);
    transition: opacity 0.15s ease, transform 0.15s ease;
  }

  .remember input:checked + .checkmark {
    background-color: var(--color-red);
    border-color: var(--color-red);
  }

  .remember input:checked + .checkmark svg {
    opacity: 1;
    transform: scale(1);
  }

  .remember input:focus-visible + .checkmark {
    box-shadow: 0 0 0 3px rgba(213, 21, 33, 0.2);
  }

  .link {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    transition: color 0.2s ease;
  }

  .link:hover {
    color: var(--color-red);
  }

  .link-strong {
    color: var(--color-red);
    font-weight: 600;
  }

  .link-strong:hover {
    color: var(--color-red-dark);
  }

  .btn-submit {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    margin-top: 0.35rem;
    padding: 0.85rem 1.75rem;
    border: 0;
    border-radius: 999px;
    background-color: var(--color-red);
    color: #fff;
    font-family: inherit;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.2s ease, transform 0.15s ease, box-shadow 0.2s ease;
  }

  .btn-submit:hover {
    background-color: var(--color-red-dark);
    box-shadow: 0 8px 20px rgba(213, 21, 33, 0.28);
    transform: translateY(-1px);
  }

  .btn-submit:active {
    transform: translateY(0);
  }

  .btn-spinner {
    display: none;
    width: 1rem;
    height: 1rem;
    border: 2px solid rgba(255, 255, 255, 0.4);
    border-top-color: #fff;
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  .btn-submit.loading {
    pointer-events: none;
    opacity: 0.85;
  }

  .btn-submit.loading .btn-spinner {
    display: block;
  }

  .alt-action {
    margin-top: 2rem;
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }

  .forgot-note {
    margin-top: 1.5rem;
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    background-color: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    border-radius: 0.65rem;
    padding: 0.85rem 1rem;
  }

  .success-badge {
    display: grid;
    place-items: center;
    width: 4.25rem;
    height: 4.25rem;
    margin: 0 auto 1.5rem;
    border-radius: 50%;
    background-color: rgba(22, 163, 74, 0.12);
    color: #16a34a;
    animation: badge-pop 0.45s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }

  @keyframes badge-pop {
    from {
      opacity: 0;
      transform: scale(0.4);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  .success-badge svg {
    width: 2.1rem;
    height: 2.1rem;
  }

  .check-path {
    stroke-dasharray: 24;
    stroke-dashoffset: 24;
    animation: check-draw 0.4s ease 0.25s forwards;
  }

  @keyframes check-draw {
    to {
      stroke-dashoffset: 0;
    }
  }

  .demo-note {
    display: inline-block;
    margin-top: 1.25rem;
    padding: 0.35rem 0.9rem;
    border-radius: 999px;
    background-color: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    font-size: 0.78rem;
    color: var(--color-text-muted);
  }

  .form-footer {
    text-align: center;
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  /* ---------- Responsive ---------- */

  @media (max-width: 64rem) {
    .brand-panel {
      padding: 3rem 2.5rem;
    }
  }

  @media (max-width: 52rem) {
    .login {
      grid-template-columns: 1fr;
    }

    .brand-panel {
      display: none;
    }

    .form-panel {
      padding: 1.5rem 1.5rem 2rem;
    }

    .mobile-logo {
      display: block;
    }

    .form-wrap {
      padding-block: 2.5rem;
    }
  }
</style>

<script>
  const views = {
    login: document.getElementById('view-login')!,
    forgot: document.getElementById('view-forgot')!,
    sent: document.getElementById('view-sent')!,
    success: document.getElementById('view-success')!,
  };

  function showView(name: keyof typeof views) {
    Object.values(views).forEach((v) => v.setAttribute('hidden', ''));
    const view = views[name];
    view.removeAttribute('hidden');
    // Reinicia la animación de entrada.
    view.style.animation = 'none';
    void view.offsetWidth;
    view.style.animation = '';
  }

  // --- Navegación entre vistas ---
  if (location.hash === '#forgot') showView('forgot');

  document.getElementById('show-forgot')?.addEventListener('click', (e) => {
    e.preventDefault();
    showView('forgot');
    (document.getElementById('forgot-email') as HTMLInputElement)?.focus();
  });

  for (const id of ['show-login', 'sent-back', 'success-back']) {
    document.getElementById(id)?.addEventListener('click', (e) => {
      e.preventDefault();
      showView('login');
    });
  }

  // --- Validación ---
  function validate(input: HTMLInputElement): boolean {
    const field = input.closest('.field')!;
    const error = document.querySelector(`[data-error-for="${input.id}"]`);
    const valid = input.value.trim().length > 0;
    field.classList.toggle('has-error', !valid);
    error?.toggleAttribute('hidden', valid);
    if (!valid) {
      field.classList.remove('shake');
      void (field as HTMLElement).offsetWidth;
      field.classList.add('shake');
    }
    return valid;
  }

  document.querySelectorAll<HTMLInputElement>('.control input').forEach((input) => {
    input.addEventListener('input', () => {
      input.closest('.field')?.classList.remove('has-error');
      document.querySelector(`[data-error-for="${input.id}"]`)?.setAttribute('hidden', '');
    });
  });

  // --- Mostrar / ocultar contraseña ---
  const passwordInput = document.getElementById('password') as HTMLInputElement;
  const togglePassword = document.querySelector<HTMLButtonElement>('.toggle-password');

  togglePassword?.addEventListener('click', () => {
    const show = passwordInput.type === 'password';
    passwordInput.type = show ? 'text' : 'password';
    togglePassword.setAttribute('aria-pressed', String(show));
    togglePassword.setAttribute('aria-label', show ? 'Ocultar contraseña' : 'Mostrar contraseña');
    passwordInput.focus();
  });

  // --- Aviso de Bloq Mayús ---
  const capsHint = document.getElementById('caps-hint')!;
  passwordInput?.addEventListener('keyup', (e) => {
    capsHint.toggleAttribute('hidden', !e.getModifierState?.('CapsLock'));
  });
  passwordInput?.addEventListener('blur', () => capsHint.setAttribute('hidden', ''));

  // --- Recordarme (prefill con localStorage) ---
  const usernameInput = document.getElementById('username') as HTMLInputElement;
  const rememberInput = document.getElementById('remember') as HTMLInputElement;
  const REMEMBER_KEY = 'reskyt-demo-user';

  const savedUser = localStorage.getItem(REMEMBER_KEY);
  if (savedUser) {
    usernameInput.value = savedUser;
    rememberInput.checked = true;
  }

  // --- Envío simulado: login ---
  document.getElementById('form-login')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const validUser = validate(usernameInput);
    const validPass = validate(passwordInput);
    if (!validUser || !validPass) return;

    if (rememberInput.checked) {
      localStorage.setItem(REMEMBER_KEY, usernameInput.value.trim());
    } else {
      localStorage.removeItem(REMEMBER_KEY);
    }

    const button = (e.currentTarget as HTMLFormElement).querySelector('.btn-submit')!;
    button.classList.add('loading');

    setTimeout(() => {
      button.classList.remove('loading');
      const name = usernameInput.value.trim().split('@')[0];
      document.getElementById('success-name')!.textContent = name ? `, ${name}` : '';
      showView('success');
    }, 1200);
  });

  // --- Envío simulado: recuperar contraseña ---
  document.getElementById('form-forgot')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const forgotInput = document.getElementById('forgot-email') as HTMLInputElement;
    if (!validate(forgotInput)) return;

    const button = (e.currentTarget as HTMLFormElement).querySelector('.btn-submit')!;
    button.classList.add('loading');

    setTimeout(() => {
      button.classList.remove('loading');
      document.getElementById('sent-email')!.textContent = forgotInput.value.trim();
      showView('sent');
    }, 1200);
  });
</script>
