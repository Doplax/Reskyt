---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { localizeHref, isLocale, DEFAULT_LOCALE } from '../i18n';
import { contentFor } from '../i18n/content';
import { miscContent } from '../i18n/extra';

const currentLocale = isLocale(Astro.currentLocale) ? Astro.currentLocale : DEFAULT_LOCALE;
const t = contentFor(miscContent, currentLocale);
---

<Layout
  title="Gracias por contactar: información para partners de Reskyt"
  description="Hemos recibido tu solicitud: en breve nos pondremos en contacto contigo para presentarte nuestro Programa para Partners."
>
  <Header />
  <main>
    <section class="section thanks">
      <div class="container thanks-inner">
        <span class="thanks-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="32" height="32" fill="none">
            <path d="M4 12.5l5.5 5.5L20 6.5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </span>
        <h1 class="thanks-title">{t.graciasTitleStart}<span class="red">{t.graciasTitleHighlight}</span>!</h1>
        <p class="thanks-text">{t.graciasPartnerText}</p>
        <a href={localizeHref('/partners', currentLocale)} class="btn-primary">{t.graciasPartnerCta}</a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .thanks {
    min-height: 50vh;
    display: grid;
    align-items: center;
  }

  .thanks-inner {
    text-align: center;
    max-width: 36rem;
  }

  .thanks-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 4rem;
    height: 4rem;
    border-radius: 50%;
    background-color: rgba(213, 21, 33, 0.1);
    color: var(--color-red);
  }

  .thanks-title {
    margin-top: 1.5rem;
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    letter-spacing: -0.02em;
  }

  .thanks-text {
    margin-top: 1rem;
    margin-bottom: 2rem;
    font-size: 1.1rem;
    color: var(--color-text-muted);
  }
</style>
