---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import TechMarquee from '../components/TechMarquee.astro';
import FeatureCards from '../components/FeatureCards.astro';
import Maximiza from '../components/Maximiza.astro';
import DemoCta from '../components/DemoCta.astro';
import Footer from '../components/Footer.astro';
import { contentFor, funcionalidadesContent } from '../i18n/content';

const t = contentFor(funcionalidadesContent, Astro.currentLocale);
---

<Layout
  title="Funcionalidades clave para apps móviles eCommerce | Reskyt"
  description="Conoce todas las funcionalidades que puede tener tu app eCommerce: notificaciones push, integración en tiempo real, filtros, login y más"
>
  <Header />
  <main>
    <section class="section hero">
      <div class="container">
        <h1 class="hero-title">
          {t.heroStart}<span class="red">{t.heroHighlight}</span>{t.heroEnd}
        </h1>
        <p class="hero-subtitle">{t.subtitle}</p>
      </div>
    </section>

    <TechMarquee />

    <FeatureCards cards={t.conversionCards}>
      {t.convStart}<span class="red">{t.convHighlight}</span>{t.convEnd}
    </FeatureCards>

    <Maximiza />

    <FeatureCards cards={t.pushCards}>
      {t.pushStart}<span class="red">{t.pushHighlight}</span>{t.pushEnd}
    </FeatureCards>

    <DemoCta />
  </main>
  <Footer />
</Layout>

<style>
  .hero {
    padding-bottom: 2rem;
  }

  .hero-title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    letter-spacing: -0.02em;
    max-width: 48rem;
  }

  .hero-subtitle {
    margin-top: 1.5rem;
    font-size: 1.15rem;
    color: var(--color-text-muted);
    max-width: 38rem;
  }
</style>
