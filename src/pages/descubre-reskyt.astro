            <p>Retos de<br />Mantenimiento</p>
          </div>
        </div>

        <div class="challenge-banner">
          <p class="banner-highlight">Reskyt elimina estos bloqueos</p>
          <p class="banner-text">Más rápido, más económico y sin complicaciones tecnológicas.</p>
        </div>
      </div>
    </section>

    <section class="section reasons">
      <div class="container">
        <h2 class="reasons-title"><span class="red">Top 5</span> razones para el equipo de marketing</h2>
        <p class="reasons-subtitle">Convierte el compromiso en ingresos, todo en un solo lugar.</p>
        <div class="reasons-grid">
          {
            marketing.map(({ title, text }, i) => (
              <article class="card">
                <p class="card-number">{String(i + 1).padStart(2, '0')}</p>
                <h3 class="card-title">{title}</h3>
                <p class="card-text">{text}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section uwt">
      <div class="container">
        <h2 class="uwt-title">Universal Wrapping Technology (UWT)</h2>
        <p class="uwt-lead">Todo el Poder del Appselling. Sin las Complicaciones Técnicas de las Apps</p>

        <div class="uwt-features">
          {
            uwtFeatures.map(({ title, text }) => (
              <div class="uwt-feature">
                <p class="uwt-feature-title">{title}</p>
                <p class="uwt-feature-text">{text}</p>
              </div>
            ))
          }
        </div>

        <div class="uwt-stats">
          {
            uwtStats.map(({ value, label }) => (
              <div class="uwt-stat">
                <p class="uwt-stat-value">{value}</p>
                <p class="uwt-stat-label">{label}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section reasons">
      <div class="container">
        <h2 class="reasons-title"><span class="red">Top 5</span> razones para el equipo de IT</h2>
        <p class="reasons-subtitle">Una app de alto rendimiento, sin sobrecarga para IT</p>
        <div class="reasons-grid">
          {
            it.map(({ title, text }, i) => (
              <article class="card">
                <p class="card-number dark">{String(i + 1).padStart(2, '0')}</p>
                <h3 class="card-title">{title}</h3>
                <p class="card-text">{text}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <DemoCta />
  </main>
  <Footer />
</Layout>

<style>
  .challenge {
    background-color: var(--color-text);
    color: #fff;
  }

  .challenge-title {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    letter-spacing: -0.02em;
    text-align: center;
  }

  .challenge-subtitle {
    margin-top: 0.75rem;
    text-align: center;
    color: rgba(255, 255, 255, 0.7);
    font-size: 1.15rem;
  }

  .challenge-grid {
    margin-top: 3.5rem;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2.5rem 1.5rem;
    justify-items: center;
  }

  .challenge-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    text-align: center;
  }

  .challenge-item svg {
    width: 7.5rem;
    height: 7.5rem;
  }

  .challenge-item p {
    font-weight: 600;
    font-size: 1.05rem;
  }

  .challenge-banner {
    margin-top: 3.5rem;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: stretch;
  }

  .banner-highlight {
    background-color: var(--color-red);
    color: #fff;
    font-weight: 700;
    padding: 0.9rem 1.5rem;
    font-size: 1.1rem;
  }

  .banner-text {
    background-color: #fff;
    color: var(--color-text);
    font-weight: 600;
    padding: 0.9rem 1.5rem;
    font-size: 1.1rem;
  }

  .reasons-title {
    font-size: clamp(2rem, 4vw, 3rem);
    letter-spacing: -0.02em;
  }

  .reasons-subtitle {
    margin-top: 0.75rem;
    color: var(--color-text-muted);
    font-size: 1.1rem;
  }

  .reasons-grid {
    margin-top: 3rem;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .card {
    padding: 2rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background-color: var(--color-bg-soft);
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .card:hover {
    border-color: var(--color-red);
    transform: translateY(-4px);
  }

  .card-number {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    font-weight: 300;
    color: var(--color-red);
    line-height: 1;
  }

  .card-number.dark {
    color: var(--color-text);
  }

  .card-title {
    margin-top: 1.25rem;
    font-size: 1.15rem;
  }

  .card-text {
    margin-top: 0.75rem;
    font-size: 0.95rem;
    color: var(--color-text-muted);
  }

  .uwt {
    background:
      radial-gradient(45rem 30rem at 85% 0%, rgba(213, 21, 33, 0.25), transparent),
      var(--color-text);
    color: #fff;
  }

  .uwt-title {
    display: inline-block;
    background-color: var(--color-red);
    padding: 0.35rem 1rem;
    font-size: clamp(1.6rem, 3.5vw, 2.5rem);
    letter-spacing: -0.02em;
  }

  .uwt-lead {
    margin-top: 1.25rem;
    font-size: 1.25rem;
    color: rgba(255, 255, 255, 0.85);
    max-width: 40rem;
  }

  .uwt-features {
    margin-top: 3rem;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    max-width: 52rem;
  }

  .uwt-feature-title {
    font-family: var(--font-heading);
    font-weight: 600;
