---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import DemoCta from '../../components/DemoCta.astro';
import Footer from '../../components/Footer.astro';
import { localizeHref, isLocale, DEFAULT_LOCALE } from '../../i18n';
import { contentFor, casosContent } from '../../i18n/content';
import { casesContent } from '../../i18n/about-cases';

export function getStaticPaths() {
  return ['bata', 'toys-rus', 'galileo-farma'].map((slug) => ({ params: { slug } }));
}

const currentLocale = isLocale(Astro.currentLocale) ? Astro.currentLocale : DEFAULT_LOCALE;
const t = contentFor(casesContent, currentLocale);
const sectors = contentFor(casosContent, currentLocale).sectors;

// Datos fijos (imágenes, personas, cifras); los textos traducibles viven en casesContent.
const days = { es: 'días', ca: 'dies', en: 'days', it: 'giorni', nl: 'dagen' }[currentLocale];
const statValues: Record<string, string[]> = {
  bata: ['+20%', 'x4-5', 'x2', `60 ${days}`],
  'toys-rus': ['+25K', '3x', '9%', `60 ${days}`],
  'galileo-farma': ['+30%', '-6h', '20%', `30 ${days}`],
};

const cases = [
  {
    slug: 'bata',
    name: 'Bata',
    sector: sectors.bata,
    mock: '/images/cases/bata-mock.png',
    cover: '/images/cases/bata-cover.jpg',
    logo: '/images/cases/bata-logo.svg',
    person: 'Benjamin Groenewoud',
    role: 'Head of Digital Product en Bata',
    photo: '/images/cases/bata-person.jpg',
    ...t.bata,
  },
  {
    slug: 'toys-rus',
    name: "Toys 'R' Us",
    sector: sectors.toys,
    mock: '/images/cases/toys-mock.png',
    cover: '/images/cases/toys-cover.jpg',
    logo: '/images/cases/toys-logo.png',
    person: 'Gerardo Casas Fernandez',
    role: "Ecommerce Director Spain & Portugal, Toys 'R' us, Febrero 2025",
    photo: '/images/cases/toys-person.jpg',
    ...t.toys,
  },
  {
    slug: 'galileo-farma',
    name: 'Galileo Farma',
    sector: sectors.galileo,
    mock: '/images/cases/galileo-mock.png',
    cover: '/images/cases/galileo-cover.jpg',
    logo: '/images/cases/galileo-logo.svg',
    person: 'Marta Segura',
    role: 'CMO Galileo Farma',
    photo: '/images/cases/galileo-person.jpeg',
    ...t.galileo,
  },
];

const { slug } = Astro.params;
const study = cases.find((c) => c.slug === slug);
if (!study) throw new Error(`Caso de éxito desconocido: ${slug}`);
const stats = statValues[study.slug].map((value, i) => ({ value, label: study.statLabels[i] }));
const others = cases.filter((c) => c.slug !== slug);
---

<Layout
  title={`${t.badge}: ${study.name} | Reskyt`}
  description={study.lead}
  ogImage={study.cover}
>
  <Header />
  <main>
    <section class="section case-hero">
      <div class="container case-hero-grid">
        <div>
          <p class="case-badge">{t.badge}</p>
          <h1 class="case-name">{study.name}</h1>
          <p class="case-lead">{study.lead}</p>
          <img class="case-logo" src={study.logo} alt={`Logo ${study.name}`} loading="lazy" height="48" />
        </div>
        <img class="case-mock" src={study.mock} alt={`App de ${study.name}`} loading="eager" width="480" />
      </div>
    </section>

    <section class="section case-body">
      <div class="container">
        <img class="case-cover" src={study.cover} alt={`Equipo de ${study.name}`} loading="lazy" width="1200" />

        <div class="case-columns">
          <div>
            <h2 class="case-section-title">{t.goalsTitle}</h2>
            <div class="case-items">
              {
                study.goals.map(({ title, text }) => (
                  <div class="case-item">
                    <h3>{title}</h3>
                    {text && <p>{text}</p>}
                  </div>
                ))
              }
            </div>
          </div>
          <div>
            <h2 class="case-section-title">{t.implementationTitle}</h2>
            <div class="case-items">
              {
                study.implementation.map(({ title, text }) => (
                  <div class="case-item">
                    <h3>{title}</h3>
                    {text && <p>{text}</p>}
                  </div>
                ))
              }
            </div>
          </div>
        </div>

        <p class="case-about">{study.about}</p>

        <figure class="case-quote">
          <img src={study.photo} alt={study.person} loading="lazy" width="96" height="96" />
          <blockquote>“{study.quote}”</blockquote>
          <figcaption>
            <strong>{study.person}</strong>
            <span>{study.role}</span>
          </figcaption>
        </figure>
      </div>
    </section>

    <section class="section case-results">
      <div class="container">
        <h2 class="results-title">{t.resultsTitle}</h2>
        <div class="results-grid">
          {
            stats.map(({ value, label }) => (
              <div class="result">
                <p class="result-value">{value}</p>
                <p class="result-label">{label}</p>
              </div>
            ))
          }
        </div>
        <p class="case-tagline">{study.tagline}</p>
      </div>
    </section>

    <section class="section case-more">
      <div class="container">
        <h2 class="more-title">{t.moreTitle}</h2>
        <div class="more-grid">
          {
            others.map((c) => (
              <a href={localizeHref(`/casos-de-exito/${c.slug}`, currentLocale)} class="more-card">
                <span class="more-name">{c.name}</span>
                <span class="more-pill">{c.sector}</span>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <DemoCta />
  </main>
  <Footer />
</Layout>

<style>
  .case-hero {
    background-color: var(--color-bg-soft);
  }

  .case-hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
  }

  .case-badge {
    display: inline-block;
    padding: 0.3rem 1rem;
    border-radius: 999px;
    background-color: var(--color-red);
    color: #fff;
    font-size: 0.85rem;
    font-weight: 600;
  }

  .case-name {
    margin-top: 1.25rem;
    font-size: clamp(2.5rem, 5vw, 4rem);
    letter-spacing: -0.02em;
  }

  .case-lead {
    margin-top: 1.25rem;
    font-size: 1.15rem;
    color: var(--color-text-muted);
    max-width: 34rem;
  }

  .case-logo {
    margin-top: 2rem;
    max-height: 3rem;
    width: auto;
  }

  .case-mock {
    justify-self: center;
    max-width: min(26rem, 80vw);
  }

  .case-cover {
    width: 100%;
    border-radius: var(--radius);
  }

  .case-columns {
    margin-top: 3.5rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  .case-section-title {
    font-size: 1.5rem;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
  }

  .case-items {
    display: grid;
    gap: 1.25rem;
  }

  .case-item {
    padding: 1.25rem 1.5rem;
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-red);
    border-radius: 0 var(--radius) var(--radius) 0;
    background-color: var(--color-bg-soft);
  }

  .case-item h3 {
    font-size: 1.05rem;
  }

  .case-item p {
    margin-top: 0.5rem;
    font-size: 0.95rem;
    color: var(--color-text-muted);
  }

  .case-about {
    margin-top: 3rem;
    font-size: 1.05rem;
    color: var(--color-text-muted);
    max-width: 52rem;
  }

  .case-quote {
    margin: 3rem 0 0;
    padding: 2rem;
    border-radius: var(--radius);
    background-color: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    display: grid;
    gap: 1.25rem;
    max-width: 52rem;
  }

  .case-quote img {
    width: 4.5rem;
    height: 4.5rem;
    border-radius: 50%;
    object-fit: cover;
  }

  .case-quote blockquote {
    margin: 0;
    font-family: var(--font-heading);
    font-size: 1.2rem;
    line-height: 1.5;
  }

  .case-quote figcaption {
    display: grid;
  }

  .case-quote figcaption span {
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  .case-results {
    background-color: var(--color-text);
    color: #fff;
  }

  .results-title {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    letter-spacing: -0.02em;
  }

  .results-grid {
    margin-top: 2.5rem;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  .result-value {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 600;
    color: var(--color-red);
    line-height: 1;
  }

  .result-label {
    margin-top: 0.6rem;
    color: rgba(255, 255, 255, 0.75);
    font-size: 0.95rem;
  }

  .case-tagline {
    margin-top: 3rem;
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 600;
  }

  .more-title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
  }

  .more-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  .more-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background-color: var(--color-bg-soft);
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .more-card:hover {
    border-color: var(--color-red);
    transform: translateY(-3px);
  }

  .more-name {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.15rem;
  }

  .more-pill {
    padding: 0.25rem 0.9rem;
    border-radius: 999px;
    background-color: var(--color-red);
    color: #fff;
    font-size: 0.8rem;
    white-space: nowrap;
  }

  @media (min-width: 60rem) {
    .case-hero-grid {
      grid-template-columns: 1.1fr 1fr;
    }

    .case-columns {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
    }

    .results-grid {
      grid-template-columns: repeat(4, 1fr);
    }

    .more-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
