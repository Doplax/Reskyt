---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import DemoCta from '../components/DemoCta.astro';
import Footer from '../components/Footer.astro';
import { publishedApps } from '../data/published-apps';

const cases = [
  {
    name: 'Bata',
    sector: 'Moda',
    href: '/casos-de-exito/bata',
    image: '/images/cases/bata-thumb.png',
  },
  {
    name: "Toys 'R' Us",
    sector: 'Juguetes',
    href: '/casos-de-exito/toys-rus',
    image: '/images/cases/toys-thumb.png',
  },
  {
    name: 'Galileo Farma',
    sector: 'Parafarmacia',
    href: '/casos-de-exito/galileo-farma',
    image: '/images/cases/galileo-thumb.png',
  },
];
---

<Layout
  title="Casos de éxito"
  description="En Reskyt desarrollamos las Apps de los mejores eCommerce de farmacias, tiendas de deportes, cosmética, alimentación y bebidas, tiendas de moda y calzado, electrónica, muebles, etc"
>
  <Header />
  <main>
    <section class="section hero">
      <div class="container">
        <h1 class="hero-title">Casos de éxito en todos los sectores</h1>
        <p class="hero-subtitle">
          La plataforma de creación de Aplicaciones móviles más utilizada por las tiendas online en
          España, Latam y Europa.
        </p>
      </div>
    </section>

    <section class="section cases">
      <div class="container">
        <div class="case-grid">
          {
            cases.map(({ name, sector, href, image }) => (
              <a href={href} class="case-card">
                <div class="case-header">
                  <p class="case-name">{name}</p>
                  <span class="case-pill">{sector}</span>
                </div>
                <img src={image} alt={`App de ${name} creada con Reskyt`} loading="lazy" />
                <span class="case-notch" aria-hidden="true" />
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section apps">
      <div class="container">
        <h2 class="apps-title">Apps publicadas en todo el mundo</h2>
        <div class="apps-grid">
          {
            publishedApps.map(({ name, logo }) => (
              <div class="app-item">
                <img src={logo} alt={`Logo ${name}`} loading="lazy" width="64" height="64" />
                <p>{name}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <DemoCta />
  </main>
  <Footer />
</Layout>

<style>
  .hero {
    padding-bottom: 1rem;
  }

  .hero-title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    letter-spacing: -0.02em;
    max-width: 48rem;
  }

  .hero-subtitle {
    margin-top: 1.5rem;
    font-size: 1.15rem;
    color: var(--color-text-muted);
    max-width: 40rem;
  }

  .case-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .case-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding: 2rem 2rem 0;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background-color: var(--color-bg-soft);
    overflow: hidden;
    transition: transform 0.3s ease, border-color 0.3s ease;
  }

  .case-card:hover {
    transform: translateY(-20px);
    border-color: var(--color-red);
  }

  /* Barra inferior que se ensancha al pasar el ratón, como en la web oficial */
  .case-notch {
    position: absolute;
    bottom: 0.75rem;
    left: 50%;
    transform: translateX(-50%);
    width: 3rem;
    height: 0.3rem;
    border-radius: 999px;
    background-color: var(--color-red);
    transition: width 0.3s ease;
  }

  .case-card:hover .case-notch {
    width: 6.25rem;
  }

  .case-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .case-name {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.25rem;
  }

  .case-pill {
    padding: 0.25rem 0.9rem;
    border-radius: 999px;
    background-color: var(--color-red);
    color: #fff;
    font-size: 0.8rem;
    font-weight: 500;
    white-space: nowrap;
  }

  .case-card img {
    width: 100%;
    border-radius: 1rem 1rem 0 0;
    object-fit: cover;
    object-position: top;
  }

  .apps-title {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    letter-spacing: -0.02em;
    margin-bottom: 3rem;
  }

  .apps-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 2rem 1.5rem;
  }

  .app-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    text-align: center;
  }

  .app-item img {
    width: 4rem;
    height: 4rem;
    object-fit: contain;
    border-radius: 1rem;
    box-shadow: 0 4px 12px rgba(22, 22, 26, 0.08);
  }

  .app-item p {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 60rem) {
    .case-grid {
      grid-template-columns: 1fr;
    }

    .apps-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
