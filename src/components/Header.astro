---
const navLinks = [
  { label: 'Funcionalidades', href: '/funcionalidades' },
  { label: 'Casos de éxito', href: '/casos-de-exito-app' },
  { label: 'Precios', href: '/precios' },
  { label: 'Blog', href: '/noticias-ecommerce-app' },
];
---

<header class="header">
  <div class="container header-inner">
    <a href="/" class="logo-link" aria-label="Reskyt – Inicio">
      <img src="/images/logo-reskyt.svg" alt="Reskyt" width="143" height="32" />
    </a>

    <nav class="nav" id="main-nav" aria-label="Navegación principal">
      {navLinks.map(({ label, href }) => <a href={href} class="nav-link">{label}</a>)}
      <a
        href="https://administracion.reskyt.com/admin/login"
        target="_blank"
        rel="noopener"
        class="nav-link login-link"
      >
        Login
      </a>
      <a href="/contacta" class="btn-primary nav-cta">Contacta</a>
    </nav>

    <button class="menu-toggle" id="menu-toggle" aria-expanded="false" aria-controls="main-nav" aria-label="Abrir menú">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 50;
    background-color: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    height: 4.5rem;
  }

  .nav {
    display: flex;
    align-items: center;
    gap: 1.75rem;
  }

  .nav-link {
    font-size: 0.95rem;
    font-weight: 500;
    transition: color 0.2s ease;
  }

  .nav-link:hover {
    color: var(--color-red);
  }

  .nav-cta {
    padding: 0.6rem 1.4rem;
  }

  .menu-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: 0;
    padding: 0.5rem;
    cursor: pointer;
  }

  .menu-toggle span {
    width: 22px;
    height: 2px;
    background-color: var(--color-text);
  }

  @media (max-width: 48rem) {
    .menu-toggle {
      display: flex;
    }

    .nav {
      display: none;
      position: absolute;
      top: 4.5rem;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: flex-start;
      padding: 1.5rem;
      background-color: var(--color-bg);
      border-bottom: 1px solid var(--color-border);
    }

    .nav.open {
      display: flex;
    }
  }
</style>

<script>
  const toggle = document.getElementById('menu-toggle');
  const nav = document.getElementById('main-nav');

  toggle?.addEventListener('click', () => {
    const isOpen = nav?.classList.toggle('open') ?? false;
    toggle.setAttribute('aria-expanded', String(isOpen));
  });
</script>
