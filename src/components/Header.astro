---
import { getDict, localizePath, localizeHref, LOCALES, isLocale, DEFAULT_LOCALE } from '../i18n';

const currentLocale = isLocale(Astro.currentLocale) ? Astro.currentLocale : DEFAULT_LOCALE;
const t = getDict(currentLocale);

const navLinks = [
  { label: t.nav.funcionalidades, href: localizeHref('/funcionalidades', currentLocale) },
  { label: t.nav.casosDeExito, href: localizeHref('/casos-de-exito-app', currentLocale) },
  { label: t.nav.precios, href: localizeHref('/precios', currentLocale) },
  { label: t.nav.blog, href: localizeHref('/noticias-ecommerce-app', currentLocale) },
];

const otherLocales = LOCALES.filter((locale) => locale !== currentLocale).map((locale) => ({
  code: locale,
  href: localizePath(Astro.url.pathname, locale),
}));
---

<header class="header">
  <div class="container header-inner">
    <a href={localizePath('/', currentLocale)} class="logo-link" aria-label="Reskyt – Inicio">
      <img src="/images/logo-reskyt.svg" alt="Reskyt" width="143" height="32" />
    </a>

    <nav class="nav" id="main-nav" aria-label={t.nav.ariaMain}>
      {navLinks.map(({ label, href }) => <a href={href} class="nav-link">{label}</a>)}
      <a href={localizeHref('/admin/login', currentLocale)} class="nav-link login-link">{t.nav.login}</a>
      <a href={localizeHref('/contacta', currentLocale)} class="btn-primary nav-cta">{t.nav.contacta}</a>

      <div class="lang-switcher" id="lang-switcher">
        <button
          type="button"
          class="lang-current"
          id="lang-toggle"
          aria-expanded="false"
          aria-controls="lang-menu"
          aria-label={t.nav.ariaLang}
        >
          {currentLocale.toUpperCase()}
        </button>
        <ul class="lang-menu" id="lang-menu">
          {
            otherLocales.map(({ code, href }) => (
              <li>
                <a href={href} class="lang-option" lang={code} data-locale={code}>
                  {code.toUpperCase()}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </nav>

    <button class="menu-toggle" id="menu-toggle" aria-expanded="false" aria-controls="main-nav" aria-label="Abrir menú">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 50;
    background-color: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    height: 4.5rem;
  }

  .nav {
    display: flex;
    align-items: center;
    gap: 1.75rem;
  }

  .nav-link {
    font-size: 0.95rem;
    font-weight: 500;
    transition: color 0.2s ease;
  }

  .nav-link:hover {
    color: var(--color-red);
  }

  .nav-cta {
    padding: 0.6rem 1.4rem;
  }

  .lang-switcher {
    position: relative;
  }

  .lang-current {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.6rem 1rem;
    border: 0;
    border-radius: var(--radius, 0.5rem);
    background-color: var(--color-red);
    color: #fff;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.2s ease;
  }

  .lang-current:hover {
    background-color: var(--color-red-dark);
  }

  .lang-menu {
    display: none;
    position: absolute;
    top: calc(100% + 0.35rem);
    right: 0;
    min-width: 100%;
    margin: 0;
    padding: 0;
    list-style: none;
    background-color: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    border-radius: var(--radius, 0.5rem);
    box-shadow: 0 0.75rem 1.5rem rgba(22, 22, 26, 0.12);
    overflow: hidden;
  }

  .lang-switcher.open .lang-menu {
    display: block;
  }

  .lang-option {
    display: block;
    padding: 0.7rem 1rem;
    font-size: 0.95rem;
    font-weight: 600;
    text-align: center;
    transition: color 0.2s ease, background-color 0.2s ease;
  }

  .lang-option:hover {
    color: var(--color-red);
    background-color: var(--color-bg);
  }

  .lang-menu li + li {
    border-top: 1px solid var(--color-border);
  }

  .menu-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: 0;
    padding: 0.5rem;
    cursor: pointer;
  }

  .menu-toggle span {
    width: 22px;
    height: 2px;
    background-color: var(--color-text);
  }

  @media (max-width: 48rem) {
    .menu-toggle {
      display: flex;
    }

    .nav {
      display: none;
      position: absolute;
      top: 4.5rem;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: flex-start;
      padding: 1.5rem;
      background-color: var(--color-bg);
      border-bottom: 1px solid var(--color-border);
    }

    .nav.open {
      display: flex;
    }

    .lang-menu {
      position: static;
      box-shadow: none;
    }
  }
</style>

<script>
  const toggle = document.getElementById('menu-toggle');
  const nav = document.getElementById('main-nav');

  toggle?.addEventListener('click', () => {
    const isOpen = nav?.classList.toggle('open') ?? false;
    toggle.setAttribute('aria-expanded', String(isOpen));
  });

  const langSwitcher = document.getElementById('lang-switcher');
  const langToggle = document.getElementById('lang-toggle');

  langToggle?.addEventListener('click', (event) => {
    event.stopPropagation();
    const isOpen = langSwitcher?.classList.toggle('open') ?? false;
    langToggle.setAttribute('aria-expanded', String(isOpen));
  });

  // Persistencia del idioma elegido: se guarda al usar el selector y
  // Layout redirige la portada al idioma preferido en la próxima visita.
  document.querySelectorAll<HTMLAnchorElement>('.lang-option').forEach((option) => {
    option.addEventListener('click', () => {
      const locale = option.dataset.locale;
      if (locale) localStorage.setItem('reskyt-locale', locale);
    });
  });

  document.addEventListener('click', () => {
    langSwitcher?.classList.remove('open');
    langToggle?.setAttribute('aria-expanded', 'false');
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') {
      langSwitcher?.classList.remove('open');
      langToggle?.setAttribute('aria-expanded', 'false');
    }
  });
</script>
