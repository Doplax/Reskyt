---
import { getDict } from '../i18n';

const t = getDict(Astro.currentLocale);
---

<section class="section cta">
  <div class="container cta-inner">
    <h2 class="cta-title">
      {t.cta.titleStart}<span class="red">{t.cta.titleHighlight}</span>{t.cta.titleEnd}
    </h2>
    <p class="cta-text">{t.cta.text}</p>
    <div class="cta-buttons">
      <a href="/solicitar-una-demo" class="btn-primary">{t.hero.demo}</a>
      <a href="/contacta" class="btn-secondary">{t.nav.contacta}</a>
    </div>
  </div>
</section>

<style>
  .cta-inner {
    text-align: center;
    max-width: 44rem;
  }

  .cta-title {
    font-size: clamp(2rem, 4vw, 3rem);
    letter-spacing: -0.02em;
  }

  .cta-text {
    margin-top: 1.25rem;
    color: var(--color-text-muted);
    font-size: 1.1rem;
  }

  .cta-buttons {
    margin-top: 2rem;
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 1rem;
  }
</style>
