---
import { getDict } from '../i18n';

const t = getDict(Astro.currentLocale);

const cards = t.appselling.cards.map((card, i) => ({
  number: String(i + 1).padStart(2, '0'),
  ...card,
}));
---

<section class="section appselling">
  <div class="container">
    <div class="intro">
      <div class="intro-title">
        <h2>{t.appselling.titleStart}<span class="red">{t.appselling.titleHighlight}</span></h2>
        <a href="/descubre-reskyt" class="btn-primary">{t.appselling.more}</a>
      </div>
      <div class="intro-text">
        <p>{t.appselling.intro1}</p>
        <p>{t.appselling.intro2}</p>
      </div>
    </div>

    <div class="cards">
      {
        cards.map(({ number, title, text }) => (
          <article class="card">
            <p class="card-number">{number}</p>
            <h3 class="card-title">{title}</h3>
            <p class="card-text">{text}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .intro {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  .intro-title {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.5rem;
  }

  .intro-title h2 {
    font-size: clamp(2rem, 4vw, 3rem);
    letter-spacing: -0.02em;
  }

  .intro-text {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    color: var(--color-text-muted);
  }

  .cards {
    margin-top: 4rem;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .card {
    padding: 2rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background-color: var(--color-bg-soft);
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .card:hover {
    border-color: var(--color-red);
    transform: translateY(-4px);
  }

  .card-number {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    font-weight: 300;
    color: var(--color-red);
    line-height: 1;
  }

  .card-title {
    margin-top: 1.25rem;
    font-size: 1.15rem;
  }

  .card-text {
    margin-top: 0.75rem;
    font-size: 0.95rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 60rem) {
    .intro {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .cards {
      grid-template-columns: 1fr;
    }
  }
</style>
