---
// Sección "Nuestros números": teléfono central con las cifras conectadas por líneas rojas.
import { getDict } from '../i18n';

const t = getDict(Astro.currentLocale);

const statsLeft = [
  { value: '+1000', label: t.stats.appsCreadas },
  { value: '+75M', label: t.stats.push },
  { value: '+25M', label: t.stats.descargas },
];

const statsRight = [
  { value: '+500K', label: t.stats.visitas },
  { value: '3x', label: t.stats.conversion },
  { value: 'ROI', label: t.stats.roi },
];
---

<section class="section stats">
  <div class="container">
    <h2 class="stats-title">
      <span class="stats-title-top">{t.stats.titleTop}</span>
      <span class="stats-title-bottom red">{t.stats.titleBottom}</span>
    </h2>

    <div class="stats-scene">
      <img
        class="stats-phone"
        src="/images/mockup-numbers.avif"
        alt={t.stats.phoneAlt}
        loading="lazy"
        width="420"
      />

      <div class="stat stat-1">
        <p class="stat-value" data-value={statsLeft[0].value}>{statsLeft[0].value}</p>
        <p class="stat-label">{statsLeft[0].label}</p>
      </div>
      <div class="stat stat-2">
        <p class="stat-value" data-value={statsLeft[1].value}>{statsLeft[1].value}</p>
        <p class="stat-label">{statsLeft[1].label}</p>
      </div>
      <div class="stat stat-3">
        <p class="stat-value" data-value={statsLeft[2].value}>{statsLeft[2].value}</p>
        <p class="stat-label">{statsLeft[2].label}</p>
      </div>
      <div class="stat stat-4">
        <p class="stat-value" data-value={statsRight[0].value}>{statsRight[0].value}</p>
        <p class="stat-label">{statsRight[0].label}</p>
      </div>
      <div class="stat stat-5">
        <p class="stat-value" data-value={statsRight[1].value}>{statsRight[1].value}</p>
        <p class="stat-label">{statsRight[1].label}</p>
      </div>
      <div class="stat stat-6">
        <p class="stat-value" data-value={statsRight[2].value}>{statsRight[2].value}</p>
        <p class="stat-label">{statsRight[2].label}</p>
      </div>

      <span class="connector connector-1" aria-hidden="true"></span>
      <span class="connector connector-2" aria-hidden="true"></span>
      <span class="connector connector-3" aria-hidden="true"></span>
      <span class="connector connector-4" aria-hidden="true"></span>
      <span class="connector connector-5" aria-hidden="true"></span>
      <span class="connector connector-6" aria-hidden="true"></span>
    </div>
  </div>
</section>

<style>
  .stats {
    background-color: var(--color-bg-soft);
    overflow: hidden;
  }

  .stats-title {
    display: flex;
    flex-direction: column;
    align-items: center;
    line-height: 0.9;
  }

  .stats-title-top {
    font-size: clamp(2rem, 4vw, 3.25rem);
    align-self: center;
    transform: translateX(-2.5em);
  }

  .stats-title-bottom {
    font-size: clamp(2.75rem, 6vw, 5rem);
    transform: translateX(1em);
  }

  .stats-scene {
    position: relative;
    margin-top: 2rem;
    min-height: 42rem;
  }

  .stats-phone {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: min(26rem, 34vw);
    filter: drop-shadow(0 2rem 2.5rem rgba(22, 22, 26, 0.25));
    z-index: 2;
  }

  .stat {
    position: absolute;
    max-width: 14rem;
    z-index: 3;
  }

  .stat-value {
    position: relative;
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 4vw, 3.5rem);
    font-weight: 600;
    line-height: 1;
    color: var(--color-red);
  }

  /* Eco difuminado detrás de cada cifra */
  .stat-value::before {
    content: attr(data-value);
    position: absolute;
    inset: 0;
    transform: translate(0.35em, 0.12em);
    filter: blur(10px);
    opacity: 0.45;
    pointer-events: none;
  }

  .stat-label {
    margin-top: 0.35rem;
    font-size: 1rem;
    color: var(--color-text);
  }

  .stat-1 { left: 12%; top: 14%; }
  .stat-2 { left: 8%; top: 44%; }
  .stat-3 { left: 12%; top: 74%; }
  .stat-4 { left: 65%; top: 16%; }
  .stat-5 { left: 68%; top: 48%; }
  .stat-6 { left: 70%; top: 74%; }

  /* Las líneas viven bajo el teléfono (z-index) y se prolongan por detrás
     de él, de modo que siempre terminan tocando el borde del móvil. */
  .connector {
    position: absolute;
    border: 0 solid var(--color-red);
    pointer-events: none;
    z-index: 1;
  }

  /* +1000: sube desde el número y gira a la derecha hasta la esquina superior del teléfono */
  .connector-1 {
    left: 12.75%;
    top: 10%;
    width: 28%;
    height: 3.5%;
    border-left-width: 2px;
    border-top-width: 2px;
  }

  /* +75M: línea recta hasta el lateral del teléfono */
  .connector-2 {
    left: 20%;
    top: 47.8%;
    width: 16.5%;
    border-top-width: 2px;
  }

  /* +25M: baja desde la etiqueta y gira a la derecha hasta la base del teléfono */
  .connector-3 {
    left: 12.75%;
    top: 88.5%;
    width: 33%;
    height: 3%;
    border-left-width: 2px;
    border-bottom-width: 2px;
  }

  /* +500K: línea recta desde el teléfono */
  .connector-4 {
    left: 53.5%;
    top: 19.8%;
    width: 11%;
    border-top-width: 2px;
  }

  /* 3x: línea recta desde el teléfono */
  .connector-5 {
    left: 56.5%;
    top: 51.8%;
    width: 11%;
    border-top-width: 2px;
  }

  /* ROI: línea recta desde el teléfono */
  .connector-6 {
    left: 58%;
    top: 77.8%;
    width: 11.5%;
    border-top-width: 2px;
  }

  /* Estado inicial de la animación (solo si hay JS: la clase anim la pone el script) */
  .stats-scene.anim .stat {
    opacity: 0;
    transform: translateY(0.75rem);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .stats-scene.anim .connector {
    opacity: 0;
    transition: opacity 0.6s ease 0.45s;
  }

  .stats-scene.anim.in .stat {
    opacity: 1;
    transform: none;
  }

  .stats-scene.anim.in .connector {
    opacity: 1;
  }

  @media (max-width: 60rem), (prefers-reduced-motion: reduce) {
    .stats-scene.anim .stat,
    .stats-scene.anim .connector {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  @media (max-width: 60rem) {
    .stats-title-top,
    .stats-title-bottom {
      transform: none;
    }

    .stats-scene {
      min-height: 0;
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem 1.5rem;
      justify-items: center;
      text-align: center;
    }

    .stats-phone {
      position: static;
      transform: none;
      grid-column: 1 / -1;
      width: min(18rem, 70vw);
      margin-inline: auto;
    }

    .stat {
      position: static;
      max-width: none;
    }

    .connector {
      display: none;
    }
  }
</style>

<script>
  // Cifras con contador animado al entrar la sección en el viewport.
  const scene = document.querySelector('.stats-scene');
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  function countUp(el: HTMLElement) {
    const target = el.dataset.value ?? '';
    const match = target.match(/^(\D*)(\d+)(.*)$/);
    if (!match) return;

    const [, prefix, digits, suffix] = match;
    const end = Number(digits);
    const duration = 1500;
    const start = performance.now();

    function frame(now: number) {
      const progress = Math.min((now - start) / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      const value = `${prefix}${Math.round(end * eased)}${suffix}`;
      el.textContent = value;
      el.dataset.value = value; // el eco difuminado (::before) lee este atributo
      if (progress < 1) requestAnimationFrame(frame);
    }

    requestAnimationFrame(frame);
  }

  if (scene && !reduceMotion && 'IntersectionObserver' in window) {
    scene.classList.add('anim');

    const observer = new IntersectionObserver(
      (entries) => {
        if (!entries.some((entry) => entry.isIntersecting)) return;
        scene.classList.add('in');
        scene.querySelectorAll<HTMLElement>('.stat-value').forEach(countUp);
        observer.disconnect();
      },
      { threshold: 0.25 }
    );

    observer.observe(scene);
  }
</script>
