---

<section class="section maximiza">
  <div class="container">
    <h2 class="maximiza-title">
      <span class="red">{t.maximizaTitleHighlight}</span>{t.maximizaTitleEnd}
    </h2>
    <p class="maximiza-subtitle">
      {t.maximizaSubtitleStart}<strong>{t.maximizaSubtitleBold}</strong>{t.maximizaSubtitleEnd}
    </p>

    <div class="stats-grid">
      {
        stats.map(({ value, label }) => (
          <div class="stat">
            <p class="stat-value">{value}</p>
            <p class="stat-label">{label}</p>
          </div>
        ))
      }
    </div>

    <div class="features-row">
      {
        features.map(({ icon }, i) => (
          <div class="feature">
            <div class="feature-icon" set:html={icon} />
            <p>{t.maximizaFeatures[i]}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .maximiza {
    background-color: var(--color-text);
    color: #fff;
  }

  .maximiza-title {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    letter-spacing: -0.02em;
    max-width: 40rem;
  }

  .maximiza-subtitle {
    margin-top: 1.25rem;
    color: rgba(255, 255, 255, 0.75);
    font-size: 1.1rem;
  }

  .stats-grid {
    margin-top: 3rem;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }

  .stat-value {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    line-height: 1;
  }

  .stat-label {
    margin-top: 0.5rem;
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.9rem;
  }

  .features-row {
    margin-top: 4rem;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 2rem;
  }

  .feature {
    text-align: center;
  }

  .feature-icon :global(svg) {
    width: 6rem;
    height: 6rem;
    margin-inline: auto;
  }

  .feature p {
    margin-top: 1rem;
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.85);
  }

  @media (max-width: 60rem) {
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .features-row {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
