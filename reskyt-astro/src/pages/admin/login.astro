---
// Réplica del login del panel de administración (administracion.reskyt.com/admin/login).
// Los formularios apuntan a los endpoints originales; en esta versión estática son decorativos.
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="robots" content="noindex,nofollow" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Login</title>
    <link rel="icon" type="image/svg+xml" href="/images/admin/favicon-admin.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <main class="login-page">
      <header class="login-header">
        <img src="/images/admin/backstage.svg" alt="Reskyt Backstage" width="220" />
      </header>

      <div class="type-login" aria-hidden="true">
        <span class="line"></span>
        <span class="name">ADMINISTRACIÓN</span>
        <span class="line"></span>
      </div>

      <div class="card">
        <form action="/admin/login_check" method="POST" id="form-login">
          <input type="text" name="_username" placeholder="Usuario" autocomplete="username" />
          <input
            type="password"
            name="_password"
            placeholder="Contraseña"
            autocomplete="current-password"
          />
          <div class="buttons">
            <a class="toggle-link" href="#" id="show-forgot">¿Has olvidado tu contraseña?</a>
            <button class="btn-submit" type="submit">Entrar</button>
          </div>
        </form>

        <form action="/admin/forgot" method="POST" id="form-forgot" hidden>
          <h2>Recuperar contraseña</h2>
          <label for="usernameForgot">Introduce nombre de usuario o e-mail:</label>
          <input type="text" name="usernameForgot" id="usernameForgot" required />
          <p class="forgot-note">
            Si no recuerda el usuario o el e-mail asociado a Reskyt puede contactar a
            <a href="mailto:info@reskyt.com">info@reskyt.com</a>
          </p>
          <div class="buttons">
            <a class="toggle-link" href="#" id="show-login">Acceder</a>
            <button class="btn-submit" type="submit">Entrar</button>
          </div>
        </form>
      </div>
    </main>
  </body>
</html>

<style>
  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    min-height: 100vh;
    font-family: 'Inter', sans-serif;
    background-image: url('/images/admin/wallpaper-2.webp');
    background-size: cover;
    background-position: center;
  }

  .login-page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.75rem;
    padding: 1.5rem;
  }

  .type-login {
    display: flex;
    align-items: center;
    gap: 1rem;
    width: 100%;
    max-width: 24rem;
  }

  .type-login .line {
    flex: 1;
    height: 1px;
    background-color: rgba(255, 255, 255, 0.6);
  }

  .type-login .name {
    color: #fff;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.25em;
  }

  .card {
    width: 100%;
    max-width: 24rem;
    padding: 2rem;
    border-radius: 1rem;
    background-color: rgba(255, 255, 255, 0.95);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.35);
  }

  form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  h2 {
    margin: 0;
    font-size: 1.15rem;
  }

  label {
    font-size: 0.85rem;
    color: #555;
  }

  input {
    padding: 0.75rem 1rem;
    border: 1px solid #d9d9de;
    border-radius: 0.5rem;
    font-size: 0.95rem;
    font-family: inherit;
  }

  input:focus {
    outline: 2px solid #dc143c;
    outline-offset: 1px;
    border-color: transparent;
  }

  .forgot-note {
    margin: 0;
    font-size: 11px;
    font-style: italic;
    color: #dc143c;
  }

  .forgot-note a {
    color: inherit;
    font-weight: 600;
  }

  .buttons {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 0.5rem;
  }

  .toggle-link {
    font-size: 0.8rem;
    color: #555;
    text-decoration: none;
  }

  .toggle-link:hover {
    color: #dc143c;
  }

  .btn-submit {
    padding: 0.7rem 2rem;
    border: 0;
    border-radius: 999px;
    background-color: #dc143c;
    color: #fff;
    font-family: inherit;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.2s ease;
  }

  .btn-submit:hover {
    background-color: #b01031;
  }
</style>

<script>
  const loginForm = document.getElementById('form-login');
  const forgotForm = document.getElementById('form-forgot');

  document.getElementById('show-forgot')?.addEventListener('click', (e) => {
    e.preventDefault();
    loginForm?.setAttribute('hidden', '');
    forgotForm?.removeAttribute('hidden');
  });

  document.getElementById('show-login')?.addEventListener('click', (e) => {
    e.preventDefault();
    forgotForm?.setAttribute('hidden', '');
    loginForm?.removeAttribute('hidden');
  });
</script>
