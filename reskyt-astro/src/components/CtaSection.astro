<section class="section cta">
  <div class="container cta-inner">
    <h2 class="cta-title">
      ¿Listo para lanzar la app de tu <span class="red">eCommerce</span>?
    </h2>
    <p class="cta-text">
      Pide una demo y descubre cómo transformar tu tienda online en una app nativa en menos de
      cuatro semanas.
    </p>
    <div class="cta-buttons">
      <a href="/solicitar-una-demo" class="btn-primary">Pide tu demo</a>
      <a href="/contacta" class="btn-secondary">Contacta</a>
    </div>
  </div>
</section>

<style>
  .cta-inner {
    text-align: center;
    max-width: 44rem;
  }

  .cta-title {
    font-size: clamp(2rem, 4vw, 3rem);
    letter-spacing: -0.02em;
  }

  .cta-text {
    margin-top: 1.25rem;
    color: var(--color-text-muted);
    font-size: 1.1rem;
  }

  .cta-buttons {
    margin-top: 2rem;
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 1rem;
  }
</style>
