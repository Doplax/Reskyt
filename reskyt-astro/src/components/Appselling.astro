---
const cards = [
  {
    number: '01',
    title: 'Sin extensos plazos de lanzamiento',
    text: 'Tu App, totalmente operativa, lista en menos de cuatro semanas.',
  },
  {
    number: '02',
    title: 'Sin elevados costes de desarrollo y mantenimiento',
    text: 'Reduce los costes de desarrollo en un 80%. Disfruta de un modelo de suscripción con actualizaciones incluidas y sin gastos de mantenimiento.',
  },
  {
    number: '03',
    title: 'Sin escalabilidad limitada, ni rigidez operativa',
    text: 'Activa actualizaciones y personalizaciones, sin fricciones ni conocimientos técnicos.',
  },
  {
    number: '04',
    title: 'Sin constantes sincronizaciones',
    text: 'Tu app siempre conectada con tu eCommerce y actualizada en tiempo real.',
  },
  {
    number: '05',
    title: 'Sin depender del equipo de IT',
    text: 'Convierte tu app en un canal de ventas autogestionado sin necesidad de intervención técnica.',
  },
  {
    number: '06',
    title: 'Sin necesitar recursos especializados',
    text: 'Tu App siempre optimizada para iOS y Android sin necesidad de equipos técnicos.',
  },
];
---

<section class="section appselling">
  <div class="container">
    <div class="intro">
      <div class="intro-title">
        <h2>Descubre el <span class="red">Appselling</span></h2>
        <a href="/descubre-reskyt" class="btn-primary">Descubre más</a>
      </div>
      <div class="intro-text">
        <p>
          Una fórmula ágil, rentable y eficaz para aumentar tu tasa de conversión, ticket medio y
          recurrencia de compra.
        </p>
        <p>
          Aprovecha todo el poder del App Commerce, sin complicaciones técnicas, y gracias a
          tecnología UWT de Reskyt.
        </p>
      </div>
    </div>

    <div class="cards">
      {
        cards.map(({ number, title, text }) => (
          <article class="card">
            <p class="card-number">{number}</p>
            <h3 class="card-title">{title}</h3>
            <p class="card-text">{text}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .intro {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  .intro-title {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.5rem;
  }

  .intro-title h2 {
    font-size: clamp(2rem, 4vw, 3rem);
    letter-spacing: -0.02em;
  }

  .intro-text {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    color: var(--color-text-muted);
  }

  .cards {
    margin-top: 4rem;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .card {
    padding: 2rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background-color: var(--color-bg-soft);
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .card:hover {
    border-color: var(--color-red);
    transform: translateY(-4px);
  }

  .card-number {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    font-weight: 300;
    color: var(--color-red);
    line-height: 1;
  }

  .card-title {
    margin-top: 1.25rem;
    font-size: 1.15rem;
  }

  .card-text {
    margin-top: 0.75rem;
    font-size: 0.95rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 60rem) {
    .intro {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .cards {
      grid-template-columns: 1fr;
    }
  }
</style>
